<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Presentation.Controls.MarqueeTagsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <!-- 뷰포트(Clip 경계) → Track(수평 이동, Translation 속성으로 Compositor 스레드 제어) → Rep1 | Spacer | Rep2 -->
    <Grid x:Name="Viewport">
        <StackPanel x:Name="Track" Orientation="Horizontal" VerticalAlignment="Center">

            <!-- 원본 태그 그룹 -->
            <ItemsRepeater x:Name="Rep1">
                <ItemsRepeater.Layout>
                    <muxc:StackLayout Orientation="Horizontal" Spacing="4" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Padding="8,4" CornerRadius="4" MinWidth="30"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock Text="{x:Bind}" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- +N 배지 (비-애니메이션 overflow 시에만 표시) -->
            <Border x:Name="OverflowBadge" Visibility="Collapsed"
                    Padding="6,4" CornerRadius="4"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    VerticalAlignment="Center" Margin="4,0,0,0">
                <TextBlock x:Name="OverflowText" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>

            <!-- 마키 반복 간격 (애니메이션 시에만 표시) -->
            <Border x:Name="Spacer" Width="30" Visibility="Collapsed" />

            <!-- 복사본 태그 그룹 (마키 이음새 처리용, 애니메이션 시에만 표시) -->
            <ItemsRepeater x:Name="Rep2" Visibility="Collapsed">
                <ItemsRepeater.Layout>
                    <muxc:StackLayout Orientation="Horizontal" Spacing="4" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Padding="8,4" CornerRadius="4" MinWidth="30"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock Text="{x:Bind}" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Grid>

</UserControl>
