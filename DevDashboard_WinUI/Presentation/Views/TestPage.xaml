<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Presentation.Views.TestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DevDashboard.Presentation.Views"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <!-- 행 마우스 오버 배경 — 코드비하인드에서 조회하므로 팔레트 색을 이름 있는 리소스로 둔다 -->
        <SolidColorBrush x:Key="RowHoverBrush" Color="{ThemeResource SubtleFillColorTertiary}" />

        <!--
            테스트 항목 행 — 시안 구성(좌측 상태 아이콘 + 이름·메모 / 우측 상태 pill).
            조작 버튼은 노출하지 않는다: 상태는 pill 클릭으로 순환하고, 편집·메모·삭제는 우클릭 메뉴로 한다
            (작업 칸반 카드와 동일한 방식). 방법 본문은 행에 싣지 않고 편집 다이얼로그에서 다룬다.
        -->
        <DataTemplate x:Key="TestItemRowTemplate" x:DataType="models:TestItem">
            <!-- 상단 1px 선이 행 사이 구분선이 된다(첫 행의 선은 헤더와 목록을 가른다) -->
            <Border BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    Background="Transparent"
                    PointerEntered="Row_PointerEntered"
                    PointerExited="Row_PointerExited">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="{x:Bind local:TestPage.EditTooltip}"
                                        Tag="{x:Bind}" Click="EditTest_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE70F;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{x:Bind local:TestPage.NoteTooltip}"
                                        Tag="{x:Bind}" Click="EditNote_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE70B;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="{x:Bind local:TestPage.DeleteTooltip}"
                                        Tag="{x:Bind}" Click="DeleteTest_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Border.ContextFlyout>

                <!-- Background=Transparent 유지: 빈 영역까지 hit-test 돼야 행 전체가 hover·우클릭 대상이 된다 -->
                <Grid ColumnSpacing="10" Padding="12,9" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 상태 아이콘 — 시안 기준: 세 상태 모두 동일한 라운드 사각형, 통과·실패는 소프트 틴트 배경 + 색 글리프,
                         미실행은 불투명 회색 배경 + "○" 글리프 -->
                    <Border Grid.Column="0" Grid.RowSpan="2"
                            Width="20" Height="20"
                            CornerRadius="6"
                            VerticalAlignment="Center"
                            Background="{x:Bind local:TestPage.StatusIconBackground(Status), Mode=OneWay}">
                        <TextBlock Text="{x:Bind local:TestPage.StatusGlyph(Status), Mode=OneWay}"
                                   Foreground="{x:Bind local:TestPage.StatusBrush(Status), Mode=OneWay}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{x:Bind Text, Mode=OneWay}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis" />

                    <!-- 메모 — 있을 때만 이름 아래에 인용 블록으로 붙는다 -->
                    <Border Grid.Column="1" Grid.Row="1"
                            Visibility="{x:Bind local:TestPage.NoteVisibility(ProgressNote), Mode=OneWay}"
                            Background="{ThemeResource AppInputBrush}"
                            BorderBrush="{ThemeResource AppWarningBrush}"
                            BorderThickness="2,0,0,0"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7C1;" FontSize="11"
                                      Foreground="{ThemeResource AppWarningBrush}"
                                      VerticalAlignment="Top" Margin="0,2,0,0" />
                            <TextBlock Text="{x:Bind ProgressNote, Mode=OneWay}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- 상태 pill — 클릭할 때마다 통과 → 실패 → 미실행 순으로 바뀐다.
                         MinWidth로 세 상태의 폭을 맞춘다("미실행" 3자가 최대 폭) -->
                    <Border Grid.Column="2" Grid.RowSpan="2"
                            Style="{StaticResource TagBadgeStyle}"
                            Margin="0"
                            MinWidth="52"
                            VerticalAlignment="Center"
                            Background="{x:Bind local:TestPage.StatusSoftBrush(Status), Mode=OneWay}"
                            Tag="{x:Bind}"
                            Tapped="StatusPill_Click"
                            ToolTipService.ToolTip="{x:Bind local:TestPage.StatusPillTooltip}">
                        <TextBlock Text="{x:Bind local:TestPage.StatusText(Status), Mode=OneWay}"
                                   FontSize="11"
                                   HorizontalAlignment="Stretch"
                                   TextAlignment="Center"
                                   Foreground="{x:Bind local:TestPage.StatusBrush(Status), Mode=OneWay}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!--
            스위트 그룹 — 시안 구성(폴더 아이콘 + 스위트명 + "N/M 통과" + 우측 진행바, 아래에 항목 행).
            스위트 이름수정·삭제는 두지 않는다(사용자 결정) — 스위트는 테스트 등록 시 작업 카테고리에서 만들어지고,
            표시할 항목이 없는 스위트는 아예 렌더되지 않는다.
        -->
        <DataTemplate x:Key="TestSuiteGroupTemplate" x:DataType="vm:TestSuiteGroup">
            <Border Background="{ThemeResource AppCardBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,12">
                <StackPanel>
                    <Grid ColumnSpacing="10" Padding="12,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="14"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Category.Name, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind local:TestPage.FormatPassCount(PassCount, TotalCount)}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <!-- 통과율 진행바 — ProgressBar는 트랙과 인디케이터의 높이가 서로 달라
                             통과율 0%인 스위트만 얇게 보인다. 두께를 확정하려고 직접 그린다. -->
                        <Grid Grid.Column="4" Width="120" Height="4" VerticalAlignment="Center">
                            <Border Background="{ThemeResource AppBorderStrongBrush}" CornerRadius="2" />
                            <Border Background="{x:Bind local:TestPage.PassBrush}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"
                                    Width="{x:Bind local:TestPage.IndicatorWidth(PassRate)}" />
                        </Grid>
                    </Grid>

                    <ItemsControl ItemsSource="{x:Bind Items}" ItemTemplate="{StaticResource TestItemRowTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== 헤더 ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="Back_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="{x:Bind local:TestPage.BackText}" />
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="{x:Bind local:TestPage.PageTitle}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" Margin="6,0,0,0" />

            <!-- 대상 프로젝트명 배지 — 어느 프로젝트의 테스트를 보고 있는지 헤더에서 바로 알 수 있게 한다 -->
            <Border Grid.Column="2"
                    Style="{StaticResource TagBadgeStyle}"
                    Margin="0"
                    VerticalAlignment="Center"
                    Background="{ThemeResource AppMutedSoftBrush}">
                <TextBlock Text="{x:Bind Vm.Project.Name}"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>

            <!-- 스위트(작업 카테고리) 필터 — 상태 필터와 직교하게 함께 적용된다 -->
            <ComboBox Grid.Column="5" x:Name="SuiteFilterCombo"
                      MinWidth="130" VerticalAlignment="Center"
                      SelectionChanged="SuiteFilter_SelectionChanged" />

            <Button Grid.Column="6"
                    Content="{x:Bind local:TestPage.AddButtonText}"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Center"
                    Click="AddTest_Click" />
        </Grid>

        <!-- ===== 상태 통계 카드 (가로 3등분 — 좌측 색점+라벨, 우측 큰 숫자) ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,12" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Ellipse Width="10" Height="10" Fill="{x:Bind local:TestPage.PassBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind local:TestPage.LabelPass}" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind Vm.PassCount, Mode=OneWay}"
                               FontSize="22" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Foreground="{x:Bind local:TestPage.PassBrush}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Ellipse Width="10" Height="10" Fill="{x:Bind local:TestPage.FailBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind local:TestPage.LabelFail}" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind Vm.FailCount, Mode=OneWay}"
                               FontSize="22" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Foreground="{x:Bind local:TestPage.FailBrush}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Ellipse Width="10" Height="10" Fill="{x:Bind local:TestPage.UntestedBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind local:TestPage.LabelUntested}" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind Vm.UntestedCount, Mode=OneWay}"
                               FontSize="22" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Foreground="{x:Bind local:TestPage.UntestedBrush}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 상태 필터 탭바 (각 탭에 개수 배지, 선택 탭은 밑줄) ===== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,0,0,12">
            <RadioButton Style="{StaticResource FilterTabStyle}" Tag="All" GroupName="TestStatusFilter"
                         IsChecked="True" Checked="StatusTab_Checked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind local:TestPage.LabelAll}" VerticalAlignment="Center" />
                    <!-- 선택 탭은 라벨만 굵어진다 — 개수 배지는 상속을 끊어 시안대로 보통 굵기를 유지한다 -->
                    <Border Style="{StaticResource TagBadgeStyle}" Margin="0" VerticalAlignment="Center"
                            Background="{ThemeResource AppMutedSoftBrush}">
                        <TextBlock Text="{x:Bind Vm.TotalCount, Mode=OneWay}" FontSize="10" FontWeight="Normal" />
                    </Border>
                </StackPanel>
            </RadioButton>
            <RadioButton Style="{StaticResource FilterTabStyle}" Tag="Pass" GroupName="TestStatusFilter"
                         Checked="StatusTab_Checked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind local:TestPage.LabelPass}" VerticalAlignment="Center" />
                    <Border Style="{StaticResource TagBadgeStyle}" Margin="0" VerticalAlignment="Center"
                            Background="{ThemeResource AppMutedSoftBrush}">
                        <TextBlock Text="{x:Bind Vm.PassCount, Mode=OneWay}" FontSize="10" FontWeight="Normal" />
                    </Border>
                </StackPanel>
            </RadioButton>
            <RadioButton Style="{StaticResource FilterTabStyle}" Tag="Fail" GroupName="TestStatusFilter"
                         Checked="StatusTab_Checked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind local:TestPage.LabelFail}" VerticalAlignment="Center" />
                    <Border Style="{StaticResource TagBadgeStyle}" Margin="0" VerticalAlignment="Center"
                            Background="{ThemeResource AppMutedSoftBrush}">
                        <TextBlock Text="{x:Bind Vm.FailCount, Mode=OneWay}" FontSize="10" FontWeight="Normal" />
                    </Border>
                </StackPanel>
            </RadioButton>
            <RadioButton Style="{StaticResource FilterTabStyle}" Tag="Untested" GroupName="TestStatusFilter"
                         Checked="StatusTab_Checked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind local:TestPage.LabelUntested}" VerticalAlignment="Center" />
                    <Border Style="{StaticResource TagBadgeStyle}" Margin="0" VerticalAlignment="Center"
                            Background="{ThemeResource AppMutedSoftBrush}">
                        <TextBlock Text="{x:Bind Vm.UntestedCount, Mode=OneWay}" FontSize="10" FontWeight="Normal" />
                    </Border>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- ===== 스위트 그룹 목록 ===== -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind Vm.SuiteGroups, Mode=OneWay}"
                          ItemTemplate="{StaticResource TestSuiteGroupTemplate}" />
        </ScrollViewer>
    </Grid>
</UserControl>
