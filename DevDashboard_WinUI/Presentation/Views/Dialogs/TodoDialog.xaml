<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.Presentation.Views.Dialogs.TodoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:winuiex="using:WinUIEx">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 타이틀 바 (MainWindow 스타일) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="AppTitleBarText"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,148,0"/>
        </Border>

        <!-- Row 1: 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
            <StackPanel Spacing="12">

                <!-- 탭 바 -->
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <RadioButton
                        x:Uid="TodoTabAll"
                        IsChecked="True"
                        GroupName="TodoTab"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="Tab_Checked"
                        Tag="All" />
                    <RadioButton
                        x:Uid="TodoTabActive"
                        GroupName="TodoTab"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="Tab_Checked"
                        Tag="Active" />
                    <RadioButton
                        x:Uid="TodoTabDone"
                        GroupName="TodoTab"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="Tab_Checked"
                        Tag="Completed" />
                </StackPanel>

                <!-- 새 항목 추가 -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="NewTodoBox"
                        x:Uid="NewTodoBox"
                        Grid.Column="0"
                        MaxLength="200" />
                    <Button
                        x:Uid="Btn_Add"
                        Grid.Column="1"
                        Click="AddTodo_Click" />
                </Grid>

                <!-- 목록 -->
                <ItemsControl x:Name="TodoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TodoItem">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox
                                    Grid.Column="0"
                                    Content="{x:Bind Text}"
                                    IsChecked="{x:Bind IsCompleted, Mode=OneWay}"
                                    Checked="TodoCheckBox_Changed"
                                    Unchecked="TodoCheckBox_Changed" />
                                <Button
                                    x:Uid="IconDeleteBtn"
                                    Grid.Column="1"
                                    Padding="8,4"
                                    Tag="{x:Bind}"
                                    Click="DeleteTodo_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 빈 상태 -->
                <TextBlock
                    x:Name="EmptyText"
                    x:Uid="EmptyTodoText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Padding="0,16"
                    Visibility="Collapsed" />

            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: 버튼 패널 -->
        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                <Button x:Uid="Btn_Close" Click="OnClose" />
            </StackPanel>
        </Border>
    </Grid>

</winuiex:WindowEx>
