<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Presentation.Views.Dialogs.TodoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:pmodels="using:DevDashboard.Presentation.Models"
    xmlns:local="using:DevDashboard.Presentation.Views.Dialogs"
    CornerRadius="8"
    >

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">700</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">700</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">700</x:Double>
    </ContentDialog.Resources>
    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="12" Grid.Row="0">

            <!-- 탭 바 -->
            <StackPanel Orientation="Horizontal" Spacing="0">
                <RadioButton
                    x:Name="TabWaiting"
                    IsChecked="True"
                    GroupName="TodoTab"
                    Style="{StaticResource GroupTabRadioButtonStyle}"
                    Checked="Tab_Checked"
                    Tag="Waiting" />
                <RadioButton
                    x:Name="TabActive"
                    GroupName="TodoTab"
                    Style="{StaticResource GroupTabRadioButtonStyle}"
                    Checked="Tab_Checked"
                    Tag="Active" />
                <RadioButton
                    x:Name="TabDone"
                    GroupName="TodoTab"
                    Style="{StaticResource GroupTabRadioButtonStyle}"
                    Checked="Tab_Checked"
                    Tag="Completed" />
                <RadioButton
                    x:Name="TabAll"
                    GroupName="TodoTab"
                    Style="{StaticResource GroupTabRadioButtonStyle}"
                    Checked="Tab_Checked"
                    Tag="All" />
            </StackPanel>

            <!-- 완료 탭 날짜 기준 선택 -->
            <StackPanel x:Name="CompletedGroupByPanel"
              Orientation="Horizontal" Spacing="0"
              Visibility="Collapsed">
                <RadioButton
          x:Uid="TodoGroupByCompleted"
          IsChecked="True"
          GroupName="CompletedGroupBy"
          Style="{StaticResource GroupTabRadioButtonStyle}"
          Checked="CompletedGroupBy_Checked"
          Tag="CompletedAt" />
                <RadioButton
          x:Uid="TodoGroupByCreated"
          GroupName="CompletedGroupBy"
          Style="{StaticResource GroupTabRadioButtonStyle}"
          Checked="CompletedGroupBy_Checked"
          Tag="CreatedAt" />
            </StackPanel>

            <!-- 새 항목 추가 (대기 탭에서만 표시) -->
            <Grid x:Name="AddTodoPanel" ColumnSpacing="8" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
          x:Name="NewTodoBox"
          x:Uid="NewTodoBox"
          Grid.Column="0"
          TextWrapping="Wrap"
          MaxLength="200" />
                <Button
          x:Uid="Btn_Add"
          Grid.Column="1"
          Click="AddTodo_Click" />
            </Grid>

        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
            <StackPanel Spacing="12" Margin="0,0,12,12">
                <!-- 목록 (날짜 그룹) -->
                <ItemsControl x:Name="TodoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="pmodels:TodoDateGroup">
                            <StackPanel Margin="0,0,0,8">
                                <!-- 날짜 그룹 헤더 -->
                                <TextBlock
                              Text="{x:Bind DateLabel}"
                              FontSize="13" FontWeight="SemiBold"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Margin="4,4,0,6" />

                                <!-- 그룹 내 항목 목록 -->
                                <ItemsControl ItemsSource="{x:Bind Items, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TodoItem">
                                            <Border
                                          Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                          Padding="8"
                                          Margin="0,0,0,6"
                                          CornerRadius="8">

                                                <Grid Padding="0,4" ColumnSpacing="8" RowSpacing="2">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 상태 콤보박스 -->
                                                    <ComboBox
                                                        Grid.RowSpan="2" Grid.Column="0"
                                                        Tag="{x:Bind}"
                                                        MinWidth="100"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center"
                                                        Loaded="StatusComboBox_Loaded"
                                                        SelectionChanged="StatusComboBox_SelectionChanged" />
                                                    <!-- 할 일 텍스트 -->
                                                    <TextBlock
                                                        Grid.Row="0" Grid.Column="1"
                                                        TextWrapping="Wrap"
                                                        Text="{x:Bind Text, Mode=OneWay}"
                                                        VerticalAlignment="Center"
                                                        TextDecorations="{x:Bind local:TodoDialog.GetTextDecorations(IsCompleted), Mode=OneWay}"
                                                        Opacity="{x:Bind local:TodoDialog.GetOpacity(IsCompleted), Mode=OneWay}" />
                                                    <!-- 수정 버튼 (완료 아닌 경우만 활성화) -->
                                                    <Button
                                                        Grid.Row="0" Grid.Column="2"
                                                        Padding="8,4"
                                                        Tag="{x:Bind}"
                                                        IsEnabled="{x:Bind local:TodoDialog.InvertBool(IsCompleted), Mode=OneWay}"
                                                        Click="EditTodo_Click">
                                                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                                    </Button>
                                                    <!-- 삭제 버튼 -->
                                                    <Button
                                                        Grid.Row="0" Grid.Column="3"
                                                        Padding="8,4"
                                                        Tag="{x:Bind}"
                                                        Click="DeleteTodo_Click">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                    </Button>
                                                    <!-- 날짜 표시 (텍스트 아래 정렬) -->
                                                    <StackPanel
                                                        Grid.Row="1" Grid.Column="1"
                                                        Orientation="Horizontal" Spacing="12"
                                                        Margin="0,0,0,2">
                                                        <TextBlock
                                                            Text="{x:Bind local:TodoDialog.FormatCreatedAt(CreatedAt), Mode=OneWay}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                        <TextBlock
                                                            Text="{x:Bind local:TodoDialog.FormatCompletedAt(CompletedAt), Mode=OneWay}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Visibility="{x:Bind local:TodoDialog.GetCompletedVisibility(IsCompleted), Mode=OneWay}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 빈 상태 -->
                <TextBlock
              x:Name="EmptyText"
              x:Uid="EmptyTodoText"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              HorizontalAlignment="Center"
              Padding="0,16"
              Visibility="Collapsed" />

            </StackPanel>
        </ScrollViewer>
    </Grid>



</ContentDialog>
