<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.Presentation.Views.Dialogs.TodoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:pmodels="using:DevDashboard.Presentation.Models"
    xmlns:local="using:DevDashboard.Presentation.Views.Dialogs"
    xmlns:winuiex="using:WinUIEx"
    MinHeight="550" MinWidth="700"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 타이틀 바 (MainWindow 스타일) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="AppTitleBarText"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,148,0"/>
        </Border>

        <!-- Row 1: 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
            <StackPanel Spacing="12">

                <!-- 탭 바 -->
                <StackPanel Orientation="Horizontal" Spacing="0">
                    
                    <RadioButton
                        x:Uid="TodoTabActive"
                          IsChecked="True"
                        GroupName="TodoTab"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="Tab_Checked"
                        Tag="Active" />
                    <RadioButton
                        x:Uid="TodoTabDone"
                        GroupName="TodoTab"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="Tab_Checked"
                        Tag="Completed" />
                    <RadioButton
                        x:Uid="TodoTabAll"  
                        GroupName="TodoTab"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="Tab_Checked"
                        Tag="All" />
                </StackPanel>

                <!-- 완료됨 탭 날짜 기준 선택 -->
                <StackPanel x:Name="CompletedGroupByPanel"
                            Orientation="Horizontal" Spacing="0"
                            Visibility="Collapsed">
                    <RadioButton
                        x:Uid="TodoGroupByCompleted"
                        IsChecked="True"
                        GroupName="CompletedGroupBy"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="CompletedGroupBy_Checked"
                        Tag="CompletedAt" />
                    <RadioButton
                        x:Uid="TodoGroupByCreated"
                        GroupName="CompletedGroupBy"
                        Style="{StaticResource GroupTabRadioButtonStyle}"
                        Checked="CompletedGroupBy_Checked"
                        Tag="CreatedAt" />
                </StackPanel>

                <!-- 새 항목 추가 (진행 중 탭에서만 표시) -->
                <Grid x:Name="AddTodoPanel" ColumnSpacing="8" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="NewTodoBox"
                        x:Uid="NewTodoBox"
                        Grid.Column="0"
                        TextWrapping="Wrap"
                        MaxLength="200" />
                    <Button
                        x:Uid="Btn_Add"
                        Grid.Column="1"
                        Click="AddTodo_Click" />
                </Grid>

                <!-- 목록 (날짜 그룹) -->
                <ItemsControl x:Name="TodoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="pmodels:TodoDateGroup">
                            <StackPanel Margin="0,0,0,8">
                                <!-- 날짜 그룹 헤더 -->
                                <TextBlock
                                    Text="{x:Bind DateLabel}"
                                    FontSize="13" FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Margin="4,4,0,6" />

                                <!-- 그룹 내 항목 목록 -->
                                <ItemsControl ItemsSource="{x:Bind Items, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:TodoItem">
                                            <Border
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                Padding="8"
                                                Margin="0,0,0,6"
                                                CornerRadius="8">

                                                <StackPanel Spacing="2">
                                                    <Grid Padding="0,4" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox
                                                            Grid.Column="0"
                                                            IsChecked="{x:Bind IsCompleted, Mode=OneWay}"
                                                            Checked="TodoCheckBox_Changed"
                                                            Unchecked="TodoCheckBox_Changed">
                                                            <TextBlock
                                                                TextWrapping="Wrap"
                                                                Text="{x:Bind Text, Mode=OneWay}"
                                                                TextDecorations="{x:Bind local:TodoDialog.GetTextDecorations(IsCompleted), Mode=OneWay}"
                                                                Opacity="{x:Bind local:TodoDialog.GetOpacity(IsCompleted), Mode=OneWay}" />
                                                        </CheckBox>
                                                        <!-- 수정 버튼 (미완료 시에만 활성화) -->
                                                        <Button
                                                            Grid.Column="1"
                                                            Padding="8,4"
                                                            Tag="{x:Bind}"
                                                            IsEnabled="{x:Bind local:TodoDialog.InvertBool(IsCompleted), Mode=OneWay}"
                                                            Click="EditTodo_Click">
                                                            <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                                        </Button>
                                                        <!-- 삭제 버튼 -->
                                                        <Button
                                                            Grid.Column="2"
                                                            Padding="8,4"
                                                            Tag="{x:Bind}"
                                                            Click="DeleteTodo_Click">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                        </Button>
                                                    </Grid>
                                                    <!-- 날짜 표시 -->
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="36,0,0,2">
                                                        <TextBlock
                                                            Text="{x:Bind local:TodoDialog.FormatCreatedAt(CreatedAt), Mode=OneWay}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                        <TextBlock
                                                            Text="{x:Bind local:TodoDialog.FormatCompletedAt(CompletedAt), Mode=OneWay}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            Visibility="{x:Bind local:TodoDialog.GetCompletedVisibility(IsCompleted), Mode=OneWay}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 빈 상태 -->
                <TextBlock
                    x:Name="EmptyText"
                    x:Uid="EmptyTodoText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Padding="0,16"
                    Visibility="Collapsed" />

            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: 버튼 패널 -->
        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                <Button x:Uid="Btn_Close" Click="OnClose" />
            </StackPanel>
        </Border>
    </Grid>

</winuiex:WindowEx>
