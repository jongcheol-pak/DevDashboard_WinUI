<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Presentation.Views.Dialogs.InstalledAppsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vo="using:DevDashboard.Domain.ValueObjects"
    CornerRadius="8"
    Opened="OnOpened">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">500</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">500</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">600</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">600</x:Double>
    </ContentDialog.Resources>

    <Grid MinHeight="400" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 검색창 -->
        <TextBox x:Name="SearchBox"
                 x:Uid="InstalledAppsSearch"
                 Grid.Row="0"
                 TextChanged="SearchBox_TextChanged" />

        <!-- 로딩 표시 -->
        <ProgressRing x:Name="LoadingRing"
                      Grid.Row="1"
                      IsActive="True"
                      Width="40" Height="40"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- 앱 목록 -->
        <ListView x:Name="AppListView"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  SelectionMode="Single"
                  SelectionChanged="AppListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vo:InstalledAppInfo">
                    <Grid Padding="4,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 앱 아이콘 -->
                        <Image Grid.Column="0"
                               Source="{Binding IconImage}"
                               Width="32" Height="32"
                               Stretch="Uniform" />

                        <!-- 앱 이름 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>
