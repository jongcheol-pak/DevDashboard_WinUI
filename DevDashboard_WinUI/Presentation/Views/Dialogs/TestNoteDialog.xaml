<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Presentation.Views.Dialogs.TestNoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DefaultButton="Primary"
    CornerRadius="8">

    <StackPanel Spacing="12" MinWidth="360">

        <!-- 어느 테스트의 메모인지 -->
        <TextBlock
            x:Name="TargetText"
            FontSize="12"
            TextWrapping="Wrap"
            Foreground="{ThemeResource AppInfoBrush}" />

        <!-- placeholder는 접미 없는 resw 키라 x:Uid로 붙이면 빈 문자열이 된다 → 코드비하인드에서 설정 -->
        <TextBox
            x:Name="NoteBox"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            MinHeight="110"
            MaxLength="500"
            ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </StackPanel>

</ContentDialog>
