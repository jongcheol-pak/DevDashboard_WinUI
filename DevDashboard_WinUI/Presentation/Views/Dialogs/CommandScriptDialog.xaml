<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.Presentation.Views.Dialogs.CommandScriptDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Enums"
    xmlns:helpers="using:DevDashboard.Presentation.Helpers"
    xmlns:winuiex="using:WinUIEx"
    MinHeight="500" MinWidth="600"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 타이틀 바 (MainWindow 스타일) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="AppTitleBarText"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,148,0"/>
        </Border>

        <!-- Row 1: 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,12">
            <StackPanel Spacing="12" DataContext="{x:Bind Vm}">

                <!-- 설명 -->
                <TextBlock x:Uid="CmdDescLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox
                    x:Uid="CmdDescBox"
                    Text="{x:Bind Vm.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MaxLength="100" />

                <!-- 셸 타입 -->
                <TextBlock x:Uid="CmdShellLabel" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                <ComboBox
                    ItemsSource="{x:Bind Vm.ShellTypes}"
                    SelectedItem="{x:Bind Vm.SelectedShellType, Mode=TwoWay}"
                    HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ShellType">
                            <TextBlock Text="{x:Bind}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 관리자 권한 -->
                <CheckBox
                    x:Uid="CmdRunAsAdminCheck"
                    IsChecked="{x:Bind Vm.RunAsAdmin, Mode=TwoWay}" />

                <!-- 스크립트 -->
                <TextBlock x:Uid="CmdScriptLabel" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                <TextBox
                    x:Uid="CmdScriptBox"
                    Text="{x:Bind Vm.Script, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True"
                    MaxHeight="100"
                    MaxLength="300"
                    TextWrapping="Wrap"
                    helpers:TextBoxHelper.MaxLines="10" 
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    />

                <!-- 실행 폴더 -->
                <CheckBox
                    x:Uid="CmdUseWorkingDirCheck"
                    IsChecked="{x:Bind Vm.UseWorkingDirectory, Mode=TwoWay}"
                    Margin="0,8,0,0" />

                <Grid
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Uid="CmdWorkingDirBox"
                        Grid.Column="0"
                        IsReadOnly="True"
                        IsEnabled="{x:Bind Vm.UseWorkingDirectory, Mode=OneWay}"
                        Text="{x:Bind Vm.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        x:Uid="Btn_Browse"
                        Grid.Column="1"
                        IsEnabled="{x:Bind Vm.UseWorkingDirectory, Mode=OneWay}"
                        Command="{x:Bind Vm.BrowseWorkingDirectoryCommand}"
                        VerticalAlignment="Stretch" />
                </Grid>

                </StackPanel>
        </ScrollViewer>

        <!-- Row 2: 버튼 패널 -->
        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                <Button x:Uid="Btn_Save" Click="OnSave" Style="{StaticResource AccentButtonStyle}" />
                <Button x:Uid="Btn_Cancel" Click="OnCancel" />
            </StackPanel>
        </Border>
    </Grid>

</winuiex:WindowEx>
