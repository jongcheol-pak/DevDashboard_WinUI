<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.Presentation.Views.Dialogs.GitStatusDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevDashboard.Domain.ValueObjects"
    xmlns:pmodels="using:DevDashboard.Presentation.Models"
    xmlns:winuiex="using:WinUIEx">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 타이틀 바 (MainWindow 스타일) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="AppTitleBarText"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,148,0"/>
        </Border>

        <!-- Row 1: 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
            <StackPanel Spacing="12" Loaded="OnRootLoaded">

                <!-- 로딩 중 -->
                <StackPanel
                    x:Name="LoadingPanel"
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    Padding="0,24">
                    <ProgressRing IsActive="True" Width="24" Height="24" />
                    <TextBlock x:Uid="GitLoadingText" VerticalAlignment="Center" />
                </StackPanel>

                <!-- 에러 -->
                <InfoBar
                    x:Name="ErrorBar"
                    x:Uid="GitErrorBar"
                    IsOpen="False"
                    Severity="Error"
                    IsClosable="False" />

                <!-- 로드 완료 패널 -->
                <StackPanel x:Name="ContentPanel" Spacing="12" Visibility="Collapsed">

                    <!-- 브랜치 -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xF1D3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="BranchText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Rectangle Style="{StaticResource SeparatorStyle}" />

                    <!-- 변경 파일 목록 -->
                    <TextBlock x:Uid="GitCommitHistoryLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <ItemsControl x:Name="CommitList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="pmodels:GitCommitGroup">
                                <StackPanel Margin="0,0,0,8">
                                    <!-- 날짜 그룹 헤더 -->
                                    <TextBlock
                                        Text="{x:Bind DateLabel}"
                                        FontSize="14" FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Margin="4,4,0,6" />

                                    <!-- 그룹 내 커밋 목록 -->
                                    <ItemsControl ItemsSource="{x:Bind Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:GitCommit">
                                                <Border
                                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="4"
                                                    Padding="12,8"
                                                    Margin="0,0,0,4">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 단축 해시 -->
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            Text="{x:Bind ShortHash}"
                                                            FontFamily="Consolas"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            VerticalAlignment="Top"
                                                            Margin="0,1,0,0" />

                                                        <!-- 메시지 + 작성자 -->
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock
                                                                Text="{x:Bind Message}"
                                                                FontSize="13"
                                                                TextWrapping="Wrap" />
                                                            <TextBlock
                                                                Text="{x:Bind AuthorName}"
                                                                FontSize="11"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 커밋 없음 -->
                    <TextBlock
                        x:Name="NoCommitsText"
                        x:Uid="NoCommitsText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center"
                        Padding="0,24"
                        Visibility="Collapsed" />

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: 버튼 패널 -->
        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                <Button x:Uid="Btn_Close" Click="OnClose" />
            </StackPanel>
        </Border>
    </Grid>

</winuiex:WindowEx>
