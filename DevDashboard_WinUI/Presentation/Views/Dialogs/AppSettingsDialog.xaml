<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.Presentation.Views.Dialogs.AppSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.ValueObjects"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:winuiex="using:WinUIEx">
    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 타이틀 바 (MainWindow 스타일) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="AppTitleBarText"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,148,0"/>
        </Border>

        <!-- Row 1: 내용 (좌측 탐색 + 우측 콘텐츠) -->
        <Grid Grid.Row="1" Loaded="OnRootLoaded">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 탐색 -->
            <StackPanel
                Grid.Column="0"
                Spacing="2"
                Padding="0,4,12,4"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
                <RadioButton
                    IsChecked="True"
                    GroupName="SettingsNav"
                    Style="{StaticResource SettingsNavItemStyle}"
                    HorizontalAlignment="Stretch"
                    Checked="Nav_Checked"
                    Tag="0">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE713;" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock x:Uid="NavSettingsLabel" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton
                    GroupName="SettingsNav"
                    Style="{StaticResource SettingsNavItemStyle}"
                    HorizontalAlignment="Stretch"
                    Checked="Nav_Checked"
                    Tag="1">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xEC7A;" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock x:Uid="NavToolsLabel" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton
                    GroupName="SettingsNav"
                    Style="{StaticResource SettingsNavItemStyle}"
                    HorizontalAlignment="Stretch"
                    Checked="Nav_Checked"
                    Tag="2">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xED0E;" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock x:Uid="NavCodeLabel" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton
                    GroupName="SettingsNav"
                    Style="{StaticResource SettingsNavItemStyle}"
                    HorizontalAlignment="Stretch"
                    Checked="Nav_Checked"
                    Tag="3">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE946;" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock x:Uid="NavInfoLabel" FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- 우측 콘텐츠 영역 -->
            <ScrollViewer Grid.Column="1" Padding="16,4" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- 0: 설정 패널 -->
                <StackPanel x:Name="PanelSettings" Spacing="14" Visibility="Visible">
                        <TextBlock Text="시스템" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                        <toolkit:SettingsCard x:Uid="RunOnStartupCard">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8FC;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch
                                OnContent=""
                                OffContent=""
                                MinWidth="0"
                                IsOn="{x:Bind Vm.RunOnStartup, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="테마" Description="현재 앱의 테마를 변경합니다. 앱의 테마를 선택하세요.">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE790;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ComboBox
     ItemsSource="{x:Bind Vm.ThemeModeItems}"
     SelectedItem="{x:Bind Vm.SelectedThemeModeItem, Mode=TwoWay}"
     HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ThemeModeItem">
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </toolkit:SettingsCard>

                        <TextBlock Text="To-Do" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                        <toolkit:SettingsCard x:Uid="WorkLogPopupCard">
                            <toolkit:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE81C;" />
                            </toolkit:SettingsCard.HeaderIcon>
                            <ToggleSwitch 
                                OnContent=""
                                OffContent=""
                                MinWidth="0"
                                IsOn="{x:Bind Vm.ShowWorkLogPopupOnTodoComplete, Mode=TwoWay}" />   
                        </toolkit:SettingsCard>

                      
                </StackPanel>

                <!-- 1: 도구 패널 -->
                <StackPanel x:Name="PanelTools" Spacing="8" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="ToolsLabelText" Grid.Column="0" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <Button x:Uid="Btn_Add" Grid.Column="1" Click="AddTool_Click" />
                    </Grid>
                    <ItemsControl x:Name="ToolList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ToolItemViewModel">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,0,6"
                                    Padding="12,8">
                                    <StackPanel Spacing="8">
                                        <!-- 헤더 (항상 표시) -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Text="{x:Bind Name, Mode=OneWay}"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Button
                                                x:Uid="Btn_Edit"
                                                Grid.Column="1"
                                                Padding="8,4"
                                                Margin="0,0,4,0"
                                                Tag="{x:Bind}"
                                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"
                                                Click="ToolEdit_Click" />
                                            <Button
                                                ToolTipService.ToolTip="Delete"
                                                Grid.Column="2"
                                                Padding="8,4"
                                                Tag="{x:Bind}"
                                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"
                                                Click="ToolDelete_Click">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                            </Button>
                                        </Grid>
                                        <!-- 읽기 모드 경로 표시 -->
                                        <TextBlock
                                            Text="{x:Bind ExecutablePath, Mode=OneWay}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            FontSize="12"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <!-- 편집 폼 -->
                                        <StackPanel
                                            Spacing="8"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                            <TextBox
                                                x:Uid="ToolNameBox"
                                                Text="{x:Bind EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox
                                                    x:Uid="ToolPathBox"
                                                    Grid.Column="0"
                                                    Text="{x:Bind EditExecutablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button
                                                    x:Uid="Btn_Browse"
                                                    Grid.Column="1"
                                                    Command="{x:Bind BrowseExecutableCommand}" />
                                            </Grid>
                                            <TextBlock
                                                Text="{x:Bind EditErrorText, Mode=OneWay}"
                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                Visibility="{Binding EditErrorText, Converter={StaticResource StringNotEmptyToVisibility}}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                <Button x:Uid="Btn_Cancel" Tag="{x:Bind}" Click="ToolCancelEdit_Click" />
                                                <Button
                                                    x:Uid="Btn_Save"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Tag="{x:Bind}"
                                                    Click="ToolSaveEdit_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 2: 코드 패널 -->
                <StackPanel x:Name="PanelCode" Spacing="14" Visibility="Collapsed">

                    <!-- 기술 스택 태그 -->
                    <TextBlock x:Uid="TagsLabelText" Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <Border
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        Padding="8"
                        CornerRadius="4">

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
  x:Uid="TagsDescText"
  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
  FontSize="12" />
                                <TextBox Grid.Column="0" Grid.Row="1"
         x:Uid="TagInputBox"
         Text="{x:Bind Vm.NewTagText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         MaxLength="20" />
                                <Button x:Uid="Btn_Add" Grid.Column="1" Grid.Row="1" Command="{x:Bind Vm.AddTechTagCommand}" />

                                <ItemsControl Margin="0,12,0,0" Grid.Row="2" Grid.ColumnSpan="2" ItemsSource="{x:Bind Vm.AllTechStackTags, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <toolkit:WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagDisplayItem">
                                            <Border
                 Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                 CornerRadius="4"
                 Padding="8,4"                                                
                 Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{x:Bind Value}" VerticalAlignment="Center" />
                                                    <Button
                         Padding="4"
                         Background="Transparent"
                         BorderThickness="0"
                         Tag="{Binding Value}"
                         Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolToVisibility}}"
                         Click="RemoveTag_Click">
                                                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                        </Border>
                    

                        <!-- 카테고리 -->
                    <TextBlock x:Uid="CategoryLabelText" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />


                        <Border
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        Padding="8"
                        CornerRadius="4">

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.ColumnSpan="2" Grid.Row="0"
    x:Uid="CategoryDescText"
    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
    FontSize="12" />
                               
                                
                                    <TextBox Grid.Row="1"
        x:Uid="CategoryInputBox"
        Grid.Column="0"
        Text="{x:Bind Vm.NewCategoryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        MaxLength="50" />
                                    <Button x:Uid="Btn_Add" Grid.Column="1" Grid.Row="1" Command="{x:Bind Vm.AddCategoryCommand}" />
                             
                                <ItemsControl Margin="0,12,0,0" Grid.ColumnSpan="2" Grid.Row="2" ItemsSource="{x:Bind Vm.AllCategories, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <toolkit:WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagDisplayItem">
                                            <Border
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                CornerRadius="4"
                Padding="8,4"
                Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{x:Bind Value}" VerticalAlignment="Center" />
                                                    <Button
                        Padding="4"
                        Background="Transparent"
                        BorderThickness="0"
                        Tag="{Binding Value}"
                        Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolToVisibility}}"
                        Click="RemoveCategory_Click">
                                                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                       

                </StackPanel>

                <!-- 3: 정보 패널 -->
                <StackPanel x:Name="PanelInfo" Spacing="12" Visibility="Collapsed" DataContext="{x:Bind Vm}">
                    <TextBlock Text="{x:Bind Vm.AppVersion}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{Binding HasNewVersion, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{x:Bind Vm.LatestVersionText, Mode=OneWay}" VerticalAlignment="Center" />
                        <HyperlinkButton
                            x:Uid="Btn_Download"
                            Command="{x:Bind Vm.OpenLatestReleaseCommand}" />
                    </StackPanel>
                    <Rectangle Style="{StaticResource SeparatorStyle}" Margin="0,8" />
                    <TextBlock x:Uid="OpenSourceLabelText" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ItemsControl ItemsSource="{x:Bind Vm.OpenSourceLibraries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:OpenSourceItem">
                                <Grid ColumnSpacing="12" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind Name}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind License}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center" />
                                    <HyperlinkButton
                                        x:Uid="Btn_GitHub"
                                        Grid.Column="2"
                                        Tag="{x:Bind Url}"
                                        Click="OpenLicenseUrl_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>

</winuiex:WindowEx>
