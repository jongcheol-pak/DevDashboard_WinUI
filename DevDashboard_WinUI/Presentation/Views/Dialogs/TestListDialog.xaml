<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Presentation.Views.Dialogs.TestListDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:local="using:DevDashboard.Presentation.Views.Dialogs"
    CornerRadius="8">
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">700</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">700</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">700</x:Double>
    </ContentDialog.Resources>
    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="12" Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="0">
                <RadioButton x:Uid="TestTabTesting" IsChecked="True" GroupName="TestTab" Style="{StaticResource GroupTabRadioButtonStyle}" Checked="Tab_Checked" Tag="Testing" />
                <RadioButton x:Uid="TestTabFix" GroupName="TestTab" Style="{StaticResource GroupTabRadioButtonStyle}" Checked="Tab_Checked" Tag="Fix" />
                <RadioButton x:Uid="TestTabDone" GroupName="TestTab" Style="{StaticResource GroupTabRadioButtonStyle}" Checked="Tab_Checked" Tag="Done" />
                <RadioButton x:Uid="TestTabAll" GroupName="TestTab" Style="{StaticResource GroupTabRadioButtonStyle}" Checked="Tab_Checked" Tag="All" />
            </StackPanel>
            <Grid x:Name="AddCategoryPanel" ColumnSpacing="8" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewCategoryBox" x:Uid="NewCategoryBox" Grid.Column="0" MaxLength="100" />
                <Button x:Uid="Btn_Add" Grid.Column="1" Click="AddCategory_Click" />
            </Grid>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
            <StackPanel Spacing="12" Margin="0,0,12,12">
                <ItemsControl x:Name="CategoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TestCategory">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Padding="6,4" Tag="{x:Bind}" Click="EditCategory_Click" Margin="0,0,4,0">
                                            <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                        </Button>
                                        <Button Grid.Column="2" Padding="6,4" Tag="{x:Bind}" Click="DeleteCategory_Click">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{x:Bind Items, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:TestItem">
                                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" Padding="8" Margin="0,0,0,4" CornerRadius="6">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox Grid.Column="0" Tag="{x:Bind}" SelectedIndex="{x:Bind local:TestListDialog.GetStatusIndex(Status), Mode=OneWay}" SelectionChanged="StatusComboBox_SelectionChanged" MinWidth="90" Padding="8,4" VerticalAlignment="Top">
                                                            <ComboBoxItem x:Uid="TestStatusTesting" />
                                                            <ComboBoxItem x:Uid="TestStatusFix" />
                                                            <ComboBoxItem x:Uid="TestStatusDone" />
                                                        </ComboBox>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <Grid Padding="0,4" ColumnSpacing="8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" FontWeight="Bold" TextWrapping="Wrap" Text="{x:Bind Text, Mode=OneWay}" VerticalAlignment="Center" TextDecorations="{x:Bind local:TestListDialog.GetTextDecorations(Status), Mode=OneWay}" Opacity="{x:Bind local:TestListDialog.GetOpacity(Status), Mode=OneWay}" Foreground="{x:Bind local:TestListDialog.GetTextForeground(Status), Mode=OneWay}" />
                                                                <Button Grid.Column="1" Padding="8,4" Tag="{x:Bind}" IsEnabled="{x:Bind local:TestListDialog.IsNotDone(Status), Mode=OneWay}" Click="EditTest_Click">
                                                                    <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                                                </Button>
                                                                <Button Grid.Column="2" Padding="8,4" Tag="{x:Bind}" Click="DeleteTest_Click">
                                                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                                </Button>
                                                            </Grid>
                                                            <Grid Margin="0,2,0,2" ColumnSpacing="8" Visibility="{x:Bind local:TestListDialog.GetNoteVisibility(Status, ProgressNote), Mode=OneWay}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{x:Bind ProgressNote, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis" />
                                                                <Button Grid.Column="1" Padding="4,2" Tag="{x:Bind}" IsEnabled="{x:Bind local:TestListDialog.IsNotDone(Status), Mode=OneWay}" Click="EditNote_Click" VerticalAlignment="Top">
                                                                    <FontIcon Glyph="&#xE70F;" FontSize="10" />
                                                                </Button>
                                                            </Grid>
                                                            <HyperlinkButton Margin="0,0,0,0" Tag="{x:Bind}" Click="AddNote_Click" Visibility="{x:Bind local:TestListDialog.GetAddNoteVisibility(Status, ProgressNote), Mode=OneWay}">
                                                                <TextBlock x:Uid="TestAddNoteLink" FontSize="11" />
                                                            </HyperlinkButton>
                                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,2">
                                                                <TextBlock Text="{x:Bind local:TestListDialog.FormatCreatedAt(CreatedAt), Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                                <TextBlock Text="{x:Bind local:TestListDialog.FormatCompletedAt(CompletedAt), Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind local:TestListDialog.GetCompletedVisibility(Status), Mode=OneWay}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid ColumnSpacing="8" Visibility="{x:Bind local:TestListDialog.GetAddTestPanelVisibility(), Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Uid="NewTestBox" Grid.Column="0" TextWrapping="Wrap" MaxLength="200" Tag="{x:Bind}" />
                                        <Button x:Uid="Btn_Add" Grid.Column="1" Tag="{x:Bind}" Click="AddTestToCategory_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="EmptyText" x:Uid="EmptyTestText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Padding="0,16" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>