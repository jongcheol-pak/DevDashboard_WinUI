<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Presentation.Views.Dialogs.HistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:helpers="using:DevDashboard.Presentation.Helpers"
    CornerRadius="8"
    >

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">800</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
        <x:Double x:Key="ContentDialogMinHeight">700</x:Double>
    </ContentDialog.Resources>

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 검색 + 추가 + 내보내기 버튼 -->
        <Grid ColumnSpacing="8" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox
    helpers:AutoSuggestBoxHelper.MaxLength="50"
    x:Uid="HistorySearchBox"
    Grid.Column="0"
    QueryIcon="Find"
    TextChanged="SearchBox_TextChanged" />
            <Button
    x:Uid="AddHistoryBtn"
    Grid.Column="1"
    Click="ToggleAddPanel_Click" />
            <Button
    Grid.Column="2"
    Click="Export_Click">
                <FontIcon Glyph="&#xE896;" FontSize="14"
        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
        </Grid>

        <!-- 인라인 추가 폼 -->
        <Border Grid.Row="1"
x:Name="AddPanel"
Background="{ThemeResource SubtleFillColorSecondaryBrush}"
CornerRadius="6"
Padding="16,12"
Visibility="Collapsed">
            <StackPanel Spacing="10">
                <TextBlock x:Uid="HistoryAddNewHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <CalendarDatePicker x:Name="AddDatePicker" HorizontalAlignment="Stretch" />
                <ComboBox x:Name="AddKindCombo" x:Uid="AddKindCombo" HorizontalAlignment="Stretch" />
                <TextBox
        x:Name="AddTitleBox"
        x:Uid="AddTitleBox"
        TextWrapping="Wrap"
        MaxLength="200" />
                <TextBox
        x:Name="AddDescriptionBox"
        x:Uid="AddDescriptionBox"
        AcceptsReturn="True"
        MinHeight="70"
        TextWrapping="Wrap"
        MaxLength="1000"
        helpers:TextBoxHelper.MaxLines="20"
        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                <TextBlock
        x:Name="AddErrorText"
        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
        Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button x:Uid="Btn_Cancel" Click="CancelAdd_Click" />
                    <Button x:Uid="Btn_Save" Style="{StaticResource AccentButtonStyle}" Click="SaveAdd_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch">
            <StackPanel Spacing="12" Margin="0,0,12,12">

             

                <!-- 기록 목록 -->
                <ItemsControl x:Name="GroupList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:HistoryDateGroup">
                            <StackPanel Margin="0,0,0,8">
                                <!-- 날짜 헤더 -->
                                <TextBlock
                             Text="{x:Bind DateText}"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                             Margin="4,4,0,6" />
                                <!-- 항목 목록 -->
                                <ItemsControl ItemsSource="{x:Bind Entries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HistoryEntryViewModel">
                                            <Border
                                         Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                         Padding="8"
                                         Margin="0,0,0,6"
                                         CornerRadius="8"
                                         Tapped="EntryBorder_Tapped"
                                         Tag="{x:Bind}">
                                                <StackPanel>
                                                    <!-- 항상 표시: 제목 행 -->
                                                    <Grid Padding="12,8" ColumnSpacing="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon
                                                     Grid.Column="0"
                                                     Glyph="{x:Bind ExpandChevron, Mode=OneWay}"
                                                     FontSize="11"
                                                     VerticalAlignment="Center" />
                                                        <StackPanel
                                                     Grid.Column="1"
                                                     Orientation="Horizontal"
                                                     Spacing="6"
                                                     VerticalAlignment="Center">
                                                            <TextBlock
                                                         Text="{x:Bind Title}"
                                                         Style="{StaticResource BodyStrongTextBlockStyle}"
                                                         VerticalAlignment="Center" />
                                                            <!-- 유형 배지 (유형이 지정된 경우만) -->
                                                            <StackPanel
                                                         Orientation="Horizontal" Spacing="4"
                                                         VerticalAlignment="Center"
                                                         Visibility="{x:Bind KindVisibility}">
                                                                <Ellipse
                                                             Width="8" Height="8"
                                                             VerticalAlignment="Center"
                                                             Fill="{x:Bind Kind, Converter={StaticResource TagColor}}" />
                                                                <TextBlock
                                                             Text="{x:Bind Kind}"
                                                             FontSize="11"
                                                             VerticalAlignment="Center"
                                                             Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button
                                                     Grid.Column="2"
                                                     Padding="8,4"
                                                     VerticalAlignment="Center"
                                                     ToolTipService.ToolTip="{x:Bind EditTooltip}"
                                                     Tag="{x:Bind}"
                                                     Tapped="EditBtn_Tapped"
                                                     Click="EditEntry_Click">
                                                            <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                                        </Button>
                                                        <Button
                                                     Grid.Column="3"
                                                     Padding="8,4"
                                                     VerticalAlignment="Center"
                                                     ToolTipService.ToolTip="{x:Bind DeleteTooltip}"
                                                     Tag="{x:Bind}"
                                                     Tapped="DeleteBtn_Tapped"
                                                     Click="DeleteEntry_Click">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                        </Button>
                                                    </Grid>
                                                    <!-- 펼쳐진 경우: 상세 영역 -->
                                                    <StackPanel
                                                 Padding="36,0,12,8"
                                                 Spacing="4"
                                                 Visibility="{x:Bind ExpandedVisibility, Mode=OneWay}">
                                                        <TextBlock
                                                     Text="{x:Bind Description}"
                                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                     TextWrapping="Wrap"
                                                     Visibility="{x:Bind DescriptionVisibility, Mode=OneWay}" />
                                                        <TextBlock
                                                     Text="{x:Bind CreatedAtText}"
                                                     FontSize="11"
                                                     Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 빈 상태 -->
                <TextBlock
             x:Name="EmptyText"
             x:Uid="EmptyHistoryText"
             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
             HorizontalAlignment="Center"
             Padding="0,24"
             Visibility="Collapsed" />

            </StackPanel>
        </ScrollViewer>

        <!-- 페이지 컨트롤 (이전/다음 + 페이지 표시) -->
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            Spacing="8"
            HorizontalAlignment="Center"
            Visibility="{x:Bind Vm.HasEntries, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
            <Button Padding="10,4" Command="{x:Bind Vm.PrevPageCommand}" IsEnabled="{x:Bind Vm.CanPrevPage, Mode=OneWay}"
                    ToolTipService.ToolTip="{x:Bind Vm.PrevPageTooltip}">
                <FontIcon Glyph="&#xE76B;" FontSize="12" />
            </Button>
            <TextBlock
                Text="{x:Bind Vm.PageInfoText, Mode=OneWay}"
                VerticalAlignment="Center"
                MinWidth="64"
                TextAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Button Padding="10,4" Command="{x:Bind Vm.NextPageCommand}" IsEnabled="{x:Bind Vm.CanNextPage, Mode=OneWay}"
                    ToolTipService.ToolTip="{x:Bind Vm.NextPageTooltip}">
                <FontIcon Glyph="&#xE76C;" FontSize="12" />
            </Button>
        </StackPanel>
    </Grid>

</ContentDialog>
