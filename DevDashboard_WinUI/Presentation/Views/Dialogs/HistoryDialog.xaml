<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.Presentation.Views.Dialogs.HistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
     xmlns:helpers="using:DevDashboard.Presentation.Helpers"
    xmlns:winuiex="using:WinUIEx">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 타이틀 바 (MainWindow 스타일) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="AppTitleBarText"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,148,0"/>
        </Border>

        <!-- Row 1: 내용 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
            <StackPanel Spacing="12">

                <!-- 검색 + 추가 버튼 -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox
                        helpers:AutoSuggestBoxHelper.MaxLength="50"
                        x:Uid="HistorySearchBox"
                        Grid.Column="0"
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged" />
                    <Button
                        x:Uid="AddHistoryBtn"
                        Grid.Column="1"
                        Click="ToggleAddPanel_Click" />                    
                </Grid>

                <!-- 인라인 추가 폼 -->
                <Border
                    x:Name="AddPanel"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="6"
                    Padding="16,12"
                    Visibility="Collapsed">
                    <StackPanel Spacing="10">
                        <TextBlock x:Uid="HistoryAddNewHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <CalendarDatePicker x:Name="AddDatePicker" HorizontalAlignment="Stretch" />
                        <TextBox
                            x:Name="AddTitleBox"
                            x:Uid="AddTitleBox"
                            MaxLength="200" />
                        <TextBox
                            x:Name="AddDescriptionBox"
                            x:Uid="AddDescriptionBox"
                            AcceptsReturn="True"
                            MinHeight="70"
                            TextWrapping="Wrap"
                            ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        <TextBlock
                            x:Name="AddErrorText"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Visibility="Collapsed" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button x:Uid="Btn_Cancel" Click="CancelAdd_Click" />
                            <Button x:Uid="Btn_Save" Style="{StaticResource AccentButtonStyle}" Click="SaveAdd_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 기록 목록 -->
                <ItemsControl x:Name="GroupList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:HistoryDateGroup">
                            <StackPanel Margin="0,0,0,8">
                                <!-- 날짜 헤더 -->
                                <TextBlock
                                    Text="{x:Bind DateText}"
                                    FontSize="13" FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Margin="4,4,0,6" />
                                <!-- 항목 목록 -->
                                <ItemsControl ItemsSource="{x:Bind Entries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HistoryEntryViewModel">
                                            <Border
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                Padding="8"
                                                Margin="0,0,0,6"
                                                CornerRadius="8"
                                                Tapped="EntryBorder_Tapped"
                                                Tag="{x:Bind}">
                                                <StackPanel>
                                                    <!-- 항상 표시: 제목 행 -->
                                                    <Grid Padding="12,8" ColumnSpacing="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon
                                                            Grid.Column="0"
                                                            Glyph="{x:Bind ExpandChevron, Mode=OneWay}"
                                                            FontSize="11"
                                                            VerticalAlignment="Center" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Text="{x:Bind Title}"
                                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                                            VerticalAlignment="Center" />
                                                        <Button
                                                            Grid.Column="2"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"
                                                            ToolTipService.ToolTip="{x:Bind EditTooltip}"
                                                            Tag="{x:Bind}"
                                                            Tapped="EditBtn_Tapped"
                                                            Click="EditEntry_Click">
                                                            <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                                        </Button>
                                                        <Button
                                                            Grid.Column="3"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"
                                                            ToolTipService.ToolTip="{x:Bind DeleteTooltip}"
                                                            Tag="{x:Bind}"
                                                            Tapped="DeleteBtn_Tapped"
                                                            Click="DeleteEntry_Click">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                        </Button>
                                                    </Grid>
                                                    <!-- 펼쳐진 경우: 상세 영역 -->
                                                    <StackPanel
                                                        Padding="36,0,12,8"
                                                        Spacing="4"
                                                        Visibility="{x:Bind ExpandedVisibility, Mode=OneWay}">
                                                        <TextBlock
                                                            Text="{x:Bind Description}"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            TextWrapping="Wrap"
                                                            Visibility="{x:Bind DescriptionVisibility, Mode=OneWay}" />
                                                        <TextBlock
                                                            Text="{x:Bind CreatedAtText}"
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 빈 상태 -->
                <TextBlock
                    x:Name="EmptyText"
                    x:Uid="EmptyHistoryText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Padding="0,24"
                    Visibility="Collapsed" />

            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: 버튼 패널 -->
        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="8" Padding="16,12">
                    <Button
Grid.Column="2"
Click="Export_Click" >
                        <FontIcon Glyph="&#xE896;" FontSize="14"
        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                    <Button x:Uid="Btn_Close" Click="OnClose" />
                </StackPanel>
            </Grid>

         
        </Border>
    </Grid>

</winuiex:WindowEx>
