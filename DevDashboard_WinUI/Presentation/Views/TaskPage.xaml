<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Presentation.Views.TaskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DevDashboard.Presentation.Views"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <!--
            칸반 카드 템플릿 — 시안 구성(제목 + 우선순위 배지 / 설명 / 날짜 범위).
            조작은 카드 클릭(편집)과 우클릭 메뉴(편집·삭제·상태 변경)로 하며, 상태 변경은 드래그앤드롭도 함께 지원한다.
            목록 뷰는 행 모양이 달라 아래 TaskListRowTemplate을 따로 둔다.
        -->
        <DataTemplate x:Key="TaskKanbanCardTemplate" x:DataType="models:TodoItem">
            <Border
                Background="{ThemeResource AppCardBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,8"
                CanDrag="True"
                DragStarting="Card_DragStarting"
                Tapped="Card_Tapped">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="{x:Bind local:TaskPage.MenuEditText}"
                                        Tag="{x:Bind}"
                                        Click="CardMenuEdit_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE70F;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem Text="{x:Bind local:TaskPage.MenuMoveToText}">
                            <MenuFlyoutItem Text="{x:Bind local:TaskPage.LabelWaiting}"
                                            Tag="{x:Bind}" Click="CardMenuMoveWaiting_Click" />
                            <MenuFlyoutItem Text="{x:Bind local:TaskPage.LabelActive}"
                                            Tag="{x:Bind}" Click="CardMenuMoveActive_Click" />
                            <MenuFlyoutItem Text="{x:Bind local:TaskPage.LabelCompleted}"
                                            Tag="{x:Bind}" Click="CardMenuMoveCompleted_Click" />
                            <MenuFlyoutItem Text="{x:Bind local:TaskPage.LabelHold}"
                                            Tag="{x:Bind}" Click="CardMenuMoveHold_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="{x:Bind local:TaskPage.MenuDeleteText}"
                                        Tag="{x:Bind}"
                                        Click="CardMenuDelete_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Border.ContextFlyout>

                <StackPanel Spacing="6">
                    <!-- 제목 + 우선순위 배지 -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind Text, Mode=OneWay}"
                            TextWrapping="Wrap"
                            MaxLines="2"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Border
                            Grid.Column="1"
                            Style="{StaticResource TagBadgeStyle}"
                            Margin="0"
                            VerticalAlignment="Top"
                            Background="{x:Bind local:TaskPage.PriorityBadgeBrush(Priority), Mode=OneWay}">
                            <TextBlock
                                Text="{x:Bind local:TaskPage.PriorityText(Priority), Mode=OneWay}"
                                FontSize="11"
                                Foreground="{x:Bind local:TaskPage.PriorityBrush(Priority), Mode=OneWay}" />
                        </Border>
                    </Grid>

                    <!-- 설명 (최대 2줄, 넘치면 말줄임) -->
                    <TextBlock
                        Text="{x:Bind Description, Mode=OneWay}"
                        FontSize="12"
                        TextWrapping="Wrap"
                        MaxLines="2"
                        TextTrimming="CharacterEllipsis"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Visibility="{x:Bind Description, Converter={StaticResource StringNotEmptyToVisibility}, Mode=OneWay}" />

                    <!-- 시작일 – 종료일 -->
                    <TextBlock
                        Text="{x:Bind local:TaskPage.FormatDateRange(StartDate, EndDate), Mode=OneWay}"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Visibility="{x:Bind local:TaskPage.DateRangeVisibility(StartDate, EndDate), Mode=OneWay}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 칸반 열 안의 카테고리 그룹 (색 dot + 카테고리명 + 개수 + 테스트 통과율 배지) -->
        <DataTemplate x:Key="TaskColumnGroupTemplate" x:DataType="vm:TaskColumnGroup">
            <StackPanel Margin="0,0,0,2">
                <Grid ColumnSpacing="6" Margin="2,0,2,6">
                    <!-- 배지는 카테고리·개수 바로 옆에 붙인다(마지막 * 컬럼이 남는 폭을 흡수) -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse
                        Grid.Column="0"
                        Width="8" Height="8"
                        VerticalAlignment="Center"
                        Fill="{x:Bind CategoryName, Converter={StaticResource TagColor}}" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind CategoryName}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Grid.Column="2"
                        Text="{x:Bind Items.Count}"
                        FontSize="12"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <!-- 테스트 배지 — 시안 기준 3분기: 미실행(회색 테두리만·보통 굵기) / 실행+100% 미만(호박 채움·굵게) / 실행+100%(초록 채움·굵게) -->
                    <Border
                        Grid.Column="3"
                        CornerRadius="6"
                        Padding="7,2"
                        Margin="0"
                        BorderThickness="1"
                        BorderBrush="#35353C"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind local:TaskPage.IdleTestBadgeVisibility(PassRateBadge, HasTestResult)}">
                        <TextBlock
                            Text="{x:Bind PassRateBadge}"
                            FontSize="11"
                            Foreground="#8A8890" />
                    </Border>
                    <Border
                        Grid.Column="3"
                        CornerRadius="6"
                        Padding="7,2"
                        Margin="0"
                        VerticalAlignment="Center"
                        Background="{x:Bind local:TaskPage.TestBadgeBackground(IsFullPass)}"
                        Visibility="{x:Bind local:TaskPage.RanTestBadgeVisibility(PassRateBadge, HasTestResult)}">
                        <TextBlock
                            Text="{x:Bind PassRateBadge}"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{x:Bind local:TaskPage.TestBadgeForeground(IsFullPass)}" />
                    </Border>
                </Grid>
                <ItemsControl ItemsSource="{x:Bind Items}" ItemTemplate="{StaticResource TaskKanbanCardTemplate}" />
            </StackPanel>
        </DataTemplate>

        <!-- 목록 뷰 작업 행 — 시안 구성(가로 1줄: 제목·설명 / 날짜 범위 / 우선순위 배지) -->
        <DataTemplate x:Key="TaskListRowTemplate" x:DataType="models:TodoItem">
            <Border
                Background="{ThemeResource AppCardBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,11">
                <Grid ColumnSpacing="12" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 제목 + 설명 (각 1줄, 넘치면 말줄임) -->
                    <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                        <TextBlock
                            Text="{x:Bind Text, Mode=OneWay}"
                            FontSize="13.5"
                            FontWeight="Bold"
                            TextWrapping="NoWrap"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{x:Bind Description, Mode=OneWay}"
                            FontSize="12"
                            TextWrapping="NoWrap"
                            TextTrimming="CharacterEllipsis"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Visibility="{x:Bind Description, Converter={StaticResource StringNotEmptyToVisibility}, Mode=OneWay}" />
                    </StackPanel>

                    <!-- 시작일 – 종료일 -->
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind local:TaskPage.FormatDateRange(StartDate, EndDate), Mode=OneWay}"
                        FontSize="11"
                        FontFamily="Consolas"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Visibility="{x:Bind local:TaskPage.DateRangeVisibility(StartDate, EndDate), Mode=OneWay}" />

                    <!-- 우선순위 배지 -->
                    <Border
                        Grid.Column="2"
                        Style="{StaticResource TagBadgeStyle}"
                        CornerRadius="6"
                        Padding="9,3"
                        Margin="0"
                        VerticalAlignment="Center"
                        Background="{x:Bind local:TaskPage.PriorityBadgeBrush(Priority), Mode=OneWay}">
                        <TextBlock
                            Text="{x:Bind local:TaskPage.PriorityText(Priority), Mode=OneWay}"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{x:Bind local:TaskPage.PriorityBrush(Priority), Mode=OneWay}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 목록 뷰 카테고리 서브그룹 (칸반 그룹 헤더와 같은 구성: 색 dot + 카테고리명 + 개수 + 테스트 통과율 배지) -->
        <DataTemplate x:Key="TaskListCategoryTemplate" x:DataType="vm:TaskColumnGroup">
            <StackPanel Margin="4,0,0,0" Spacing="7">
                <!-- 시안은 헤더가 넘치면 줄바꿈되나(flex-wrap) StackPanel은 미지원 — 칸반 헤더와 같은 성질을 유지한다 -->
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <Border
                        Width="8" Height="8"
                        CornerRadius="3"
                        VerticalAlignment="Center"
                        Background="{x:Bind CategoryName, Converter={StaticResource TagColor}}" />
                    <TextBlock
                        Text="{x:Bind CategoryName}"
                        FontSize="12.5"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="{x:Bind Items.Count}"
                        FontSize="11.5"
                        FontFamily="Consolas"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <!-- 테스트 배지 — 칸반과 동일한 3분기: 미실행(회색 테두리만) / 실행+100% 미만(호박 채움) / 실행+100%(초록 채움) -->
                    <Border
                        CornerRadius="6"
                        Padding="7,2"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind local:TaskPage.IdleTestBadgeVisibility(PassRateBadge, HasTestResult)}">
                        <TextBlock
                            Text="{x:Bind PassRateBadge}"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </Border>
                    <Border
                        CornerRadius="6"
                        Padding="7,2"
                        VerticalAlignment="Center"
                        Background="{x:Bind local:TaskPage.TestBadgeBackground(IsFullPass)}"
                        Visibility="{x:Bind local:TaskPage.RanTestBadgeVisibility(PassRateBadge, HasTestResult)}">
                        <TextBlock
                            Text="{x:Bind PassRateBadge}"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="{x:Bind local:TaskPage.TestBadgeForeground(IsFullPass)}" />
                    </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{x:Bind Items}" ItemTemplate="{StaticResource TaskListRowTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <!-- 목록 뷰 상태 그룹 (상태 dot + 이름 + 개수 + 구분선 + "새 작업" / 항목이 없으면 "작업 없음") -->
        <DataTemplate x:Key="TaskListStatusGroupTemplate" x:DataType="vm:TaskListStatusGroup">
            <StackPanel Spacing="12">
                <Grid ColumnSpacing="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Width="9" Height="9"
                        CornerRadius="3"
                        VerticalAlignment="Center"
                        Background="{x:Bind local:TaskPage.StatusDotBrush(Status)}" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind StatusLabel}"
                        FontSize="14.5"
                        FontWeight="Bold"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Grid.Column="2"
                        Text="{x:Bind Count}"
                        FontSize="12"
                        FontFamily="Consolas"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <Rectangle
                        Grid.Column="3"
                        Style="{StaticResource SeparatorStyle}"
                        VerticalAlignment="Center" />
                    <Button
                        Grid.Column="4"
                        Height="28"
                        Padding="11,0"
                        CornerRadius="7"
                        FontSize="12"
                        Background="{ThemeResource AppInputBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Content="{x:Bind local:TaskPage.ColumnAddText}"
                        Tag="{x:Bind local:TaskPage.StatusTag(Status)}"
                        Click="ColumnAdd_Click" />
                </Grid>

                <!-- 항목이 없는 상태 (WinUI Border는 점선 테두리 미지원 → Rectangle로 그린다) -->
                <Grid Visibility="{x:Bind local:TaskPage.EmptyGroupVisibility(IsEmpty)}">
                    <Rectangle
                        RadiusX="10" RadiusY="10"
                        Fill="Transparent"
                        Stroke="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        StrokeThickness="1"
                        StrokeDashArray="3,3" />
                    <TextBlock
                        x:Uid="TaskList_Empty"
                        Margin="0,18"
                        FontSize="12.5"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                </Grid>

                <ItemsControl
                    ItemsSource="{x:Bind Categories}"
                    ItemTemplate="{StaticResource TaskListCategoryTemplate}"
                    Visibility="{x:Bind local:TaskPage.CategoriesVisibility(IsEmpty)}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== 헤더 ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,16" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="Back_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock x:Uid="TaskPage_BackText" />
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1" x:Uid="TaskPage_Title"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" Margin="6,0,0,0" />

            <!-- 카테고리 필터 -->
            <ComboBox Grid.Column="3" x:Name="CategoryFilterCombo"
                      MinWidth="130" VerticalAlignment="Center"
                      SelectionChanged="CategoryFilter_SelectionChanged" />

            <!-- 칸반/목록 세그먼트 토글 — 바깥 Border가 두 항목을 한 그룹으로 묶는다 -->
            <Border Grid.Column="4"
                    Background="{ThemeResource AppInputBrush}"
                    BorderBrush="{ThemeResource AppBorderStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="2"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <RadioButton GroupName="TaskView"
                                 Style="{StaticResource SegmentedToggleStyle}"
                                 IsChecked="{x:Bind Vm.IsKanbanView, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71D;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind local:TaskPage.ViewKanbanText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="TaskView"
                                 Style="{StaticResource SegmentedToggleStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8FD;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind local:TaskPage.ViewListText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== 본문 ===== -->
        <Grid Grid.Row="1">
            <!-- 칸반 뷰 -->
            <ScrollViewer
                x:Name="KanbanScrollViewer"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollMode="Auto"
                Visibility="{x:Bind Vm.IsKanbanView, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                <!--
                    가로 스크롤 ScrollViewer는 콘텐츠에 무한 너비를 주므로 Width="*" 열이 뷰포트에 맞지 않고
                    카드 텍스트 길이만큼 늘어나 줄바꿈(TextWrapping/MaxLines)이 깨진다.
                    Grid 너비를 뷰포트 너비에 묶어 유한하게 만들고(→ 열이 균등 분배·텍스트 줄바꿈 동작),
                    MinWidth로 좁은 창에서는 가로 스크롤이 나오게 한다(열 4개×MinWidth 230 + 간격 3×10 = 950).
                -->
                <Grid ColumnSpacing="10"
                      MinWidth="950"
                      Width="{Binding ViewportWidth, ElementName=KanbanScrollViewer}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--
                        각 열은 배경·테두리를 가진 패널이며 드롭 대상도 이 패널이다.
                        (드롭을 안쪽 목록이 아니라 패널이 받아야 카드가 없는 빈 열에도 놓을 수 있다.)
                    -->

                    <!-- 예정 -->
                    <Border Grid.Column="0" Style="{StaticResource KanbanColumnStyle}" MinWidth="230"
                            AllowDrop="True" Tag="Waiting"
                            DragOver="Column_DragOver" Drop="Column_Drop">
                        <StackPanel MinHeight="120">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,2,2,12">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind local:TaskPage.StatusDotWaiting}" />
                                <TextBlock Text="{x:Bind local:TaskPage.LabelWaiting}" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Vm.WaitingCount, Mode=OneWay}" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{x:Bind Vm.WaitingItems, Mode=OneWay}" ItemTemplate="{StaticResource TaskColumnGroupTemplate}" />
                            <Button Style="{StaticResource DashedAddButtonStyle}"
                                    Content="{x:Bind local:TaskPage.ColumnAddText}"
                                    Tag="Waiting" Click="ColumnAdd_Click" />
                        </StackPanel>
                    </Border>

                    <!-- 진행 중 -->
                    <Border Grid.Column="1" Style="{StaticResource KanbanColumnStyle}" MinWidth="230"
                            AllowDrop="True" Tag="Active"
                            DragOver="Column_DragOver" Drop="Column_Drop">
                        <StackPanel MinHeight="120">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,2,2,12">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind local:TaskPage.StatusDotActive}" />
                                <TextBlock Text="{x:Bind local:TaskPage.LabelActive}" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Vm.ActiveCount, Mode=OneWay}" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{x:Bind Vm.ActiveItems, Mode=OneWay}" ItemTemplate="{StaticResource TaskColumnGroupTemplate}" />
                            <Button Style="{StaticResource DashedAddButtonStyle}"
                                    Content="{x:Bind local:TaskPage.ColumnAddText}"
                                    Tag="Active" Click="ColumnAdd_Click" />
                        </StackPanel>
                    </Border>

                    <!-- 완료 -->
                    <Border Grid.Column="2" Style="{StaticResource KanbanColumnStyle}" MinWidth="230"
                            AllowDrop="True" Tag="Completed"
                            DragOver="Column_DragOver" Drop="Column_Drop">
                        <StackPanel MinHeight="120">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,2,2,12">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind local:TaskPage.StatusDotCompleted}" />
                                <TextBlock Text="{x:Bind local:TaskPage.LabelCompleted}" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Vm.CompletedCount, Mode=OneWay}" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{x:Bind Vm.CompletedItems, Mode=OneWay}" ItemTemplate="{StaticResource TaskColumnGroupTemplate}" />
                            <Button Style="{StaticResource DashedAddButtonStyle}"
                                    Content="{x:Bind local:TaskPage.ColumnAddText}"
                                    Tag="Completed" Click="ColumnAdd_Click" />
                        </StackPanel>
                    </Border>

                    <!-- 보류 -->
                    <Border Grid.Column="3" Style="{StaticResource KanbanColumnStyle}" MinWidth="230"
                            AllowDrop="True" Tag="Hold"
                            DragOver="Column_DragOver" Drop="Column_Drop">
                        <StackPanel MinHeight="120">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,2,2,12">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind local:TaskPage.StatusDotHold}" />
                                <TextBlock Text="{x:Bind local:TaskPage.LabelHold}" VerticalAlignment="Center" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Vm.HoldCount, Mode=OneWay}" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{x:Bind Vm.HoldItems, Mode=OneWay}" ItemTemplate="{StaticResource TaskColumnGroupTemplate}" />
                            <Button Style="{StaticResource DashedAddButtonStyle}"
                                    Content="{x:Bind local:TaskPage.ColumnAddText}"
                                    Tag="Hold" Click="ColumnAdd_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- 목록 뷰 (상태 그룹 → 카테고리 서브그룹 → 작업 행) -->
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind Vm.IsKanbanView, Converter={StaticResource InverseBoolToVisibility}, Mode=OneWay}">
                <ItemsControl
                    ItemsSource="{x:Bind Vm.ListStatusGroups, Mode=OneWay}"
                    ItemTemplate="{StaticResource TaskListStatusGroupTemplate}"
                    Padding="24,18,24,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="22" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
