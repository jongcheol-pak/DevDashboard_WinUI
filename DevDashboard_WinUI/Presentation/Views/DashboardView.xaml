<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Presentation.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:ctrl="using:DevDashboard.Presentation.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
     xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">

    <UserControl.Resources>

        <!-- 카드 아이콘 버튼 스타일 -->
        <Style x:Key="CardIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity">
                                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.3" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"               
                                              Padding="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ───── 프로젝트 카드 DataTemplate ───── -->
        <DataTemplate x:Key="ProjectCardTemplate" x:DataType="vm:ProjectCardViewModel">
            <Border Width="330" Margin="8"
                    MinHeight="204"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    CanDrag="{Binding IsPinned}"
                    AllowDrop="True"
                    DragStarting="Card_DragStarting"
                    DropCompleted="Card_DropCompleted"
                    DragOver="Card_DragOver"                  
                    Drop="Card_Drop">
                <Grid Margin="16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="38" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 카드 상단: 경고 + 아이콘 + 이름 + 핀 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 경로 오류 경고 -->
                        <FontIcon ToolTipService.ToolTip="{StaticResource ToolTip_ProjectPathNotFound}"
                                  Grid.Column="0" Glyph="&#xE7BA;" FontSize="16"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                  VerticalAlignment="Center" Margin="0,0,4,0"
                                  Visibility="{Binding IsProjectPathValid, Converter={StaticResource InverseBoolToVisibility}}" />

                        <!-- 아이콘 이미지 -->
                        <Border Grid.Column="1"
                                Width="28" Height="28" CornerRadius="4" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IconPath, Converter={StaticResource StringNotEmptyToVisibility}}">
                            <Image Source="{Binding IconSource}" Stretch="Uniform" />
                        </Border>

                        <!-- 프로젝트 이름 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Name}"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,8,0" />

                        <!-- 핀 버튼 -->
                        <Button ToolTipService.ToolTip="{StaticResource ToolTip_PinUnpin}"
                                Grid.Column="3"
                                Style="{StaticResource CardIconButtonStyle}"
                                Command="{Binding TogglePinCommand}">
                            <Grid>
                                <FontIcon Glyph="&#xE718;" FontSize="13"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Visibility="{Binding IsPinned, Converter={StaticResource InverseBoolToVisibility}}" />
                                <FontIcon Glyph="&#xE77A;" FontSize="13"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                          Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Button>
                    </Grid>

                    <!-- 설명 -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding Description}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Stretch"
                               MaxLines="2"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibility}}" />

                    <!-- 태그 영역 (마키 애니메이션 컨트롤) -->
                    <ctrl:MarqueeTagsControl Grid.Row="2"
                        Tags="{Binding Tags}"
                        IsAnimationEnabled="{Binding EnableTagAnimation}"
                        MaxTagLength="20"
                        Margin="0,4,0,4" />

                    <!-- 카드 하단 -->
                    <StackPanel Grid.Row="3" Spacing="8">

                        <!-- 개발도구 + 아이콘 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 개발도구 배지 -->
                            <Border Grid.Column="0"
                                    Background="{Binding DevToolName, Converter={StaticResource TagColor}}"
                                    CornerRadius="6" Padding="10,0" Height="34"
                                    HorizontalAlignment="Stretch" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                                    <Grid VerticalAlignment="Center"
                                          Visibility="{Binding IsDevToolValid, Converter={StaticResource BoolToVisibility}}">
                                        <FontIcon Glyph="&#xEC7A;" FontSize="14"
                                                  VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                        <FontIcon Glyph="&#xEB59;" FontSize="16"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Visibility="{Binding RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                 
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                              Visibility="{Binding IsDevToolValid, Converter={StaticResource InverseBoolToVisibility}}" />
                                    <TextBlock Text="{Binding DevToolName}"
                                               FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- 아이콘 버튼 그룹 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" >
                                <!-- 실행 버튼 -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_Run}"
                                       Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenInDevToolCommand}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="RunAsAdminMenuItem"
                                                           Command="{Binding OpenInDevToolAsAdminCommand}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <FontIcon Glyph="&#xE768;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 폴더 열기 -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_OpenFolder}"
                                        Margin="0,0,4,0"
                                      
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenFolderCommand}">
                                    <FontIcon Glyph="&#xE838;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 편집 -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_CardSettings}"
                                        Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding EditCommand}">
                                    <FontIcon Glyph="&#xE70F;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 삭제 -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_Delete}"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding DeleteCommand}">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" 
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- 커맨드 슬롯 + Git/Todo/History 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 커맨드 슬롯 버튼 (0~3) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                <!-- 슬롯 0 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                         Margin="0,0,4,0"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="0"
                                        ToolTipService.ToolTip="{Binding Cmd0Tooltip}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <!-- 미설정: + 아이콘 -->
                                        <FontIcon Glyph="&#xE710;" FontSize="14"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd0Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <!-- 설정됨: 아이콘 유무에 따라 분기 -->
                                        <Grid Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}">

                                            <FontIcon Glyph="&#xE756;" FontSize="14"           
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
 Visibility="{Binding HasCmd0Icon, Converter={StaticResource InverseBoolToVisibility}}" />


                                            <FontIcon Glyph="{Binding Cmd0Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd0Icon, Converter={StaticResource BoolToVisibility}}" />


                                            <FontIcon Glyph="&#xEB59;" FontSize="14"
           VerticalAlignment="Center"
           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
           Visibility="{Binding IsCmd0RunAsAdmin, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </Grid>
                                </Button>

                                <!-- 슬롯 1 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                         Margin="0,0,4,0"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="1"
                                        ToolTipService.ToolTip="{Binding Cmd1Tooltip}"
                                        Visibility="{Binding IsCmd1SlotVisible, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE710;" FontSize="14"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd1Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <Grid Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}">
                                            <FontIcon Glyph="&#xE756;" FontSize="14"           
           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
Visibility="{Binding HasCmd1Icon, Converter={StaticResource InverseBoolToVisibility}}" />

                                            <FontIcon Glyph="{Binding Cmd1Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd1Icon, Converter={StaticResource BoolToVisibility}}" />

                                            <FontIcon Glyph="&#xEB59;" FontSize="14"
VerticalAlignment="Center"
Foreground="{ThemeResource TextFillColorSecondaryBrush}"
Visibility="{Binding IsCmd1RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>

                                <!-- 슬롯 2 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                         Margin="0,0,4,0"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="2"
                                        ToolTipService.ToolTip="{Binding Cmd2Tooltip}"
                                        Visibility="{Binding IsCmd2SlotVisible, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE710;" FontSize="14"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd2Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <Grid Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}">
                                            <FontIcon Glyph="&#xE756;" FontSize="14"           
           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
Visibility="{Binding HasCmd2Icon, Converter={StaticResource InverseBoolToVisibility}}" />

                                            <FontIcon Glyph="{Binding Cmd2Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd2Icon, Converter={StaticResource BoolToVisibility}}" />

                                            <FontIcon Glyph="&#xEB59;" FontSize="14"
VerticalAlignment="Center"
Foreground="{ThemeResource TextFillColorSecondaryBrush}"
Visibility="{Binding IsCmd2RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>

                                <!-- 슬롯 3 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="3"
                                        ToolTipService.ToolTip="{Binding Cmd3Tooltip}"
                                        Visibility="{Binding IsCmd3SlotVisible, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE710;" FontSize="14"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd3Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <Grid Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}">
                                            <FontIcon Glyph="&#xE756;" FontSize="14"           
           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
Visibility="{Binding HasCmd3Icon, Converter={StaticResource InverseBoolToVisibility}}" />

                                            <FontIcon Glyph="{Binding Cmd3Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd3Icon, Converter={StaticResource BoolToVisibility}}" />

                                            <FontIcon Glyph="&#xEB59;" FontSize="14"
VerticalAlignment="Center"
Foreground="{ThemeResource TextFillColorSecondaryBrush}"
Visibility="{Binding IsCmd3RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>
                            </StackPanel>

                            <!-- Git / Todo / History 버튼 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="2">
                                <!-- Git 상태 (레포인 경우만) -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_GitStatus}"
                                         Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding ShowGitStatusCommand}"
                                        Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibility}}">
                                    <Path Data="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- To-Do -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_ToDo}"
                                         Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenTodoCommand}">
                                    <FontIcon Glyph="&#xEE92;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 작업 기록 -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_WorkHistory}"
                                         Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenHistoryCommand}">
                                    <FontIcon Glyph="&#xE81C;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 터미널 열기 -->
                                <Button ToolTipService.ToolTip="{StaticResource ToolTip_Terminal}"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenTerminalCommand}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="TerminalPowerShellMenuItem"
                                                           Command="{Binding OpenTerminalWithPowerShellCommand}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <FontIcon Glyph="&#xE756;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ───── + 추가 카드 DataTemplate ───── -->
        <DataTemplate x:Key="AddCardTemplate">
            <Border Width="330" Margin="8"
                    MinHeight="120"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Button HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="AddCard_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Uid="AddNewProjectText"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Button>
            </Border>
        </DataTemplate>

        <!-- ───── 드롭 플레이스홀더 DataTemplate ───── -->
        <DataTemplate x:Key="DropPlaceholderTemplate">
            <Border Width="330" Margin="8"
                    MinHeight="204"
                    CornerRadius="12"
                    BorderThickness="2"
                    BorderBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    AllowDrop="True"
                    DragOver="Placeholder_DragOver"
                    Drop="Placeholder_Drop" />
        </DataTemplate>

        <!-- ───── Template Selector ───── -->
        <ctrl:DashboardCardTemplateSelector x:Key="CardTemplateSelector"
            ProjectCardTemplate="{StaticResource ProjectCardTemplate}"
            AddCardTemplate="{StaticResource AddCardTemplate}"
            DropPlaceholderTemplate="{StaticResource DropPlaceholderTemplate}" />

    </UserControl.Resources>

    <Grid>
        <!-- 로딩 오버레이 -->
        <Grid x:Name="LoadingOverlay"
              Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="{Binding IsInitializing}" Width="40" Height="40" />
                <TextBlock x:Uid="LoadingText" FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- 카드 목록 (ScrollViewer + ItemsRepeater) -->
        <ScrollViewer x:Name="CardScrollViewer"
                      Visibility="{Binding IsInitializing, Converter={StaticResource InverseBoolToVisibility}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater x:Name="CardRepeater"
                           ItemsSource="{Binding DisplayCards}"
                           ItemTemplate="{StaticResource CardTemplateSelector}"
                           Margin="8,8,8,8">
                <ItemsRepeater.Layout>
                    <muxc:UniformGridLayout  ItemsJustification="Start" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
