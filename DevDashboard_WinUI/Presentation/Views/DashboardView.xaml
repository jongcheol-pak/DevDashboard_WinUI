<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Presentation.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:models="using:DevDashboard.Domain.Entities"
    xmlns:ctrl="using:DevDashboard.Presentation.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
     xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">

    <UserControl.Resources>

        <!--
            카드 테두리 색 — DataTemplate 안에서는 VisualStateManager가 동작하지 않아
            hover를 코드비하인드 핸들러로 처리한다. 팔레트 색을 코드에서 가져오려고 별칭 키로 둔다
            (ThemeDictionaries 안의 키는 Resources 인덱서로 조회되지 않으므로 flat 리소스가 필요하다).
        -->
        <SolidColorBrush x:Key="CardBorderBrush" Color="{ThemeResource CardStrokeColorDefault}" />
        <SolidColorBrush x:Key="CardHoverBorderBrush" Color="{ThemeResource CardStrokeColorHover}" />

        <!-- 헤더 위 아이콘 색 — 삭제 버튼은 hover에서만 위험색으로 바뀐다(시안 :360) -->
        <SolidColorBrush x:Key="HeaderIconBrush" Color="{ThemeResource CardHeaderIconColor}" />
        <SolidColorBrush x:Key="HeaderIconDangerBrush" Color="{ThemeResource CardHeaderIconDangerColor}" />
        <!-- "새 프로젝트 추가" 카드 hover 테두리 (시안 :347) -->
        <SolidColorBrush x:Key="AddCardHoverBorderBrush" Color="{ThemeResource AppAccentColor}" />

        <!-- 카드 아이콘 버튼 스타일 -->
        <Style x:Key="CardIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlStrokeColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity">
                                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.3" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"               
                                              Padding="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ───── 프로젝트 카드 DataTemplate ───── -->
        <DataTemplate x:Key="ProjectCardTemplate" x:DataType="vm:ProjectCardViewModel">
            <Border MaxWidth="360"
                    MinHeight="204"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    CanDrag="{Binding IsPinned}"
                    AllowDrop="True"
                    DragStarting="Card_DragStarting"
                    DropCompleted="Card_DropCompleted"
                    DragOver="Card_DragOver"
                    Drop="Card_Drop"
                    PointerEntered="Card_PointerEntered"
                    PointerExited="Card_PointerExited">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="62" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 카드 헤더 밴드 (시안 :353 — 프로젝트 색 그라데이션 위에 아바타·이름·핀·삭제)
                         WinUI Border는 자식을 클립하지 않으므로 상단 모서리만 직접 둥글린다 -->
                    <Border Grid.Row="0"
                            CornerRadius="13,13,0,0"
                            Padding="16,0"
                            Background="{Binding EffectiveHeaderColor, Converter={StaticResource HexToHeaderGradient}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 경로 오류 경고 (시안에는 없지만 기능이라 유지) -->
                            <FontIcon ToolTipService.ToolTip="{StaticResource ToolTip_ProjectPathNotFound}"
                                      Grid.Column="0" Glyph="&#xE7BA;" FontSize="16"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                      Visibility="{Binding IsProjectPathValid, Converter={StaticResource InverseBoolToVisibility}}" />

                            <!-- 아바타 — 아이콘이 있으면 아이콘, 없으면 이니셜 (시안 :354) -->
                            <Border Grid.Column="1"
                                    Width="38" Height="38" CornerRadius="10" Margin="0,0,11,0"
                                    VerticalAlignment="Center"
                                    Background="{Binding EffectiveHeaderColor, Converter={StaticResource HexToBrush}}">
                                <Grid>
                                    <Image Source="{Binding IconSource}" Stretch="Uniform" Margin="5"
                                           Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBlock Text="{Binding Initial}"
                                               FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasIcon, Converter={StaticResource InverseBoolToVisibility}}" />
                                </Grid>
                            </Border>

                            <!-- 프로젝트 이름 -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Name}"
                                       FontSize="14.5" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,8,0" />

                            <!-- 핀 버튼 (헤더 밴드 위 — 크기·모서리는 로컬 지정, 공용 스타일은 수정하지 않는다) -->
                            <Button ToolTipService.ToolTip="{StaticResource ToolTip_PinUnpin}"
                                    Grid.Column="3"
                                    Width="28" Height="28" CornerRadius="7"
                                    Margin="0,0,4,0"
                                    Style="{StaticResource CardIconButtonStyle}"
                                    Command="{Binding TogglePinCommand}">
                                <Grid>
                                    <FontIcon Glyph="&#xE718;" FontSize="13"
                                              Foreground="{StaticResource HeaderIconBrush}"
                                              Visibility="{Binding IsPinned, Converter={StaticResource InverseBoolToVisibility}}" />
                                    <FontIcon Glyph="&#xE77A;" FontSize="13"
                                              Foreground="White"
                                              Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </Button>

                            <!-- 삭제 — 평소엔 헤더 위 흰색, 마우스를 올렸을 때만 위험색 (시안 :360) -->
                            <Button ToolTipService.ToolTip="{StaticResource ToolTip_Delete}"
                                    Grid.Column="4"
                                    Width="28" Height="28" CornerRadius="7"
                                    Style="{StaticResource CardIconButtonStyle}"
                                    Command="{Binding DeleteCommand}"
                                    PointerEntered="DeleteButton_PointerEntered"
                                    PointerExited="DeleteButton_PointerExited">
                                <FontIcon Glyph="&#xE74D;" FontSize="13"
                                          Foreground="{StaticResource HeaderIconBrush}" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 카드 본문 (시안 :365 — padding 14/16/16, 세로 간격 12) -->
                    <StackPanel Grid.Row="1" Margin="16,14,16,16" Spacing="12">

                        <!-- 설명 — 최대 2줄, 넘치면 말줄임 (사용자 확인 2026-07-22) -->
                        <TextBlock Text="{Binding Description}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibility}}" />

                        <!-- 태그 영역 (마키 애니메이션 컨트롤) -->
                        <ctrl:MarqueeTagsControl
                            Tags="{Binding Tags}"
                            IsAnimationEnabled="{Binding EnableTagAnimation}"
                            MaxTagLength="20" />

                    <!-- 카드 하단 -->
                    <StackPanel Spacing="8">

                        <!-- 액션 행 (시안 :372~387) — 큰 실행 버튼 + 작업/테스트 + 더 보기 메뉴.
                             폴더·터미널·Git·작업 기록·설정은 '더 보기' 메뉴로 옮겼다 -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 개발 도구 실행 버튼 (누르면 실행, 우클릭하면 관리자 권한) -->
                            <Button Grid.Column="0"
                                    Height="34" CornerRadius="9" Padding="10,0"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Background="{Binding DevToolName, Converter={StaticResource TagColor}}"
                                    Command="{Binding OpenInDevToolCommand}">
                                <Button.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="RunAsAdminMenuItem"
                                                        Command="{Binding OpenInDevToolAsAdminCommand}" />
                                    </MenuFlyout>
                                </Button.ContextFlyout>
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE768;" FontSize="12" Foreground="White"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding IsDevToolValid, Converter={StaticResource BoolToVisibility}}" />
                                    <!-- 도구 경로가 잘못됐을 때 -->
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                              Visibility="{Binding IsDevToolValid, Converter={StaticResource InverseBoolToVisibility}}" />
                                    <!-- 관리자 권한으로 실행되는 프로젝트 -->
                                    <FontIcon Glyph="&#xEB59;" FontSize="14" Foreground="White"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBlock Text="{Binding DevToolName}"
                                               FontSize="12.5" FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>

                            <!-- 작업 -->
                            <Button Grid.Column="1"
                                    ToolTipService.ToolTip="{StaticResource ToolTip_ToDo}"
                                    Width="34" Height="34" CornerRadius="9"
                                    Style="{StaticResource CardIconButtonStyle}"
                                    Command="{Binding OpenTodoCommand}">
                                <FontIcon Glyph="&#xEE92;" FontSize="15"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Button>

                            <!-- 테스트 -->
                            <Button Grid.Column="2"
                                    ToolTipService.ToolTip="{StaticResource ToolTip_TestList}"
                                    Width="34" Height="34" CornerRadius="9"
                                    Style="{StaticResource CardIconButtonStyle}"
                                    Command="{Binding OpenTestListCommand}">
                                <FontIcon Glyph="&#xEBE8;" FontSize="15"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Button>

                            <!-- 구분선 (시안 :383) -->
                            <Rectangle Grid.Column="3"
                                       Width="1" Height="18"
                                       VerticalAlignment="Center"
                                       Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                            <!-- 더 보기 -->
                            <Button Grid.Column="4"
                                    ToolTipService.ToolTip="{StaticResource ToolTip_More}"
                                    Width="34" Height="34" CornerRadius="9"
                                    Style="{StaticResource CardIconButtonStyle}">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="CardMenu_Run"
                                                        Command="{Binding OpenInDevToolCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE768;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="CardMenu_OpenFolder"
                                                        Command="{Binding OpenFolderCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE838;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <!-- 터미널은 기본/PowerShell 두 갈래 — 축약 전에는 터미널 버튼 우클릭이 유일한 진입점이었다 -->
                                        <MenuFlyoutSubItem x:Uid="CardMenu_Terminal">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE756;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem x:Uid="CardMenu_TerminalDefault"
                                                            Command="{Binding OpenTerminalCommand}" />
                                            <MenuFlyoutItem x:Uid="CardMenu_TerminalPowerShell"
                                                            Command="{Binding OpenTerminalWithPowerShellCommand}" />
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem x:Uid="CardMenu_GitStatus"
                                                        Command="{Binding ShowGitStatusCommand}"
                                                        Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibility}}" />
                                        <MenuFlyoutItem x:Uid="CardMenu_History"
                                                        Command="{Binding OpenHistoryCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE81C;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="CardMenu_Settings"
                                                        Command="{Binding EditCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE713;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <!-- 삭제는 되돌릴 수 없으므로 위험색으로 구분한다(시안 :483) -->
                                        <MenuFlyoutItem x:Uid="CardMenu_Delete"
                                                        Command="{Binding DeleteCommand}"
                                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE10C;" FontSize="15"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Button>
                        </Grid>

                        <!-- 스크립트 슬롯 (시안 :388~393) — 구분선 아래, 설정된 것만 표시하고 끝에 추가 버튼 -->
                        <Border BorderThickness="0,1,0,0"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Padding="0,10,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <!-- 슬롯 0 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                        Width="28" Height="28" CornerRadius="8"
                                        Background="{ThemeResource AppInputBrush}"
                                        BorderBrush="{ThemeResource AppHoverFillBrush}"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="0"
                                        ToolTipService.ToolTip="{Binding Cmd0Tooltip}"
                                        Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <!-- 버튼 자체가 설정된 슬롯에만 보이므로 미설정 분기는 두지 않는다 -->
                                    <Grid>
                                        <FontIcon Glyph="&#xE756;" FontSize="10"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd0Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <FontIcon Glyph="{Binding Cmd0Icon}" FontSize="10"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd0Icon, Converter={StaticResource BoolToVisibility}}" />
                                        <FontIcon Glyph="&#xEB59;" FontSize="10"
                                                  VerticalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd0RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Button>

                                <!-- 슬롯 1 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                        Width="28" Height="28" CornerRadius="8"
                                        Background="{ThemeResource AppInputBrush}"
                                        BorderBrush="{ThemeResource AppHoverFillBrush}"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="1"
                                        ToolTipService.ToolTip="{Binding Cmd1Tooltip}"
                                        Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE756;" FontSize="10"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd1Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <FontIcon Glyph="{Binding Cmd1Icon}" FontSize="10"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd1Icon, Converter={StaticResource BoolToVisibility}}" />
                                        <FontIcon Glyph="&#xEB59;" FontSize="10"
                                                  VerticalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd1RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Button>

                                <!-- 슬롯 2 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                        Width="28" Height="28" CornerRadius="8"
                                        Background="{ThemeResource AppInputBrush}"
                                        BorderBrush="{ThemeResource AppHoverFillBrush}"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="2"
                                        ToolTipService.ToolTip="{Binding Cmd2Tooltip}"
                                        Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE756;" FontSize="10"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd2Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <FontIcon Glyph="{Binding Cmd2Icon}" FontSize="10"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd2Icon, Converter={StaticResource BoolToVisibility}}" />
                                        <FontIcon Glyph="&#xEB59;" FontSize="10"
                                                  VerticalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd2RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Button>

                                <!-- 슬롯 3 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                        Width="28" Height="28" CornerRadius="8"
                                        Background="{ThemeResource AppInputBrush}"
                                        BorderBrush="{ThemeResource AppHoverFillBrush}"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="3"
                                        ToolTipService.ToolTip="{Binding Cmd3Tooltip}"
                                        Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}"
                                        ContextRequested="CmdSlot_ContextRequested">
                                    <Button.ContextFlyout>
                                        <MenuFlyout Opening="CmdFlyout_Opening">
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE756;" FontSize="10"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd3Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <FontIcon Glyph="{Binding Cmd3Icon}" FontSize="10"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding HasCmd3Icon, Converter={StaticResource BoolToVisibility}}" />
                                        <FontIcon Glyph="&#xEB59;" FontSize="10"
                                                  VerticalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd3RunAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Button>

                                <!-- 슬롯 추가 (시안 :393 — 점선 테두리. WinUI Border는 점선을 못 그려
                                     Rectangle StrokeDashArray를 쓰는 공용 스타일을 재사용한다) -->
                                <Button Style="{StaticResource DashedAddButtonStyle}"
                                        Width="28" Height="28" Padding="0"
                                        ToolTipService.ToolTip="{StaticResource ToolTip_AddScript}"
                                        Command="{Binding AddCommandSlotCommand}"
                                        Visibility="{Binding CanAddCommandSlot, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE710;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ───── + 추가 카드 DataTemplate ───── -->
        <DataTemplate x:Key="AddCardTemplate">
            <Border MaxWidth="360"
                    MinHeight="150"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    PointerEntered="AddCard_PointerEntered"
                    PointerExited="AddCard_PointerExited">
                <Button HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="AddCard_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE710;" FontSize="26"
                                  HorizontalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Uid="AddNewProjectText"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Button>
            </Border>
        </DataTemplate>

        <!-- ───── 드롭 플레이스홀더 DataTemplate ───── -->
        <DataTemplate x:Key="DropPlaceholderTemplate">
            <Border MaxWidth="360"
                    MinHeight="204"
                    CornerRadius="14"
                    BorderThickness="2"
                    BorderBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    AllowDrop="True"
                    DragOver="Placeholder_DragOver"
                    Drop="Placeholder_Drop" />
        </DataTemplate>

        <!-- ───── Template Selector ───── -->
        <ctrl:DashboardCardTemplateSelector x:Key="CardTemplateSelector"
            ProjectCardTemplate="{StaticResource ProjectCardTemplate}"
            AddCardTemplate="{StaticResource AddCardTemplate}"
            DropPlaceholderTemplate="{StaticResource DropPlaceholderTemplate}" />

    </UserControl.Resources>

    <Grid>
        <!-- 로딩 오버레이 -->
        <Grid x:Name="LoadingOverlay"
              Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="{Binding IsInitializing}" Width="40" Height="40" />
                <TextBlock x:Uid="LoadingText" FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- 카드 목록 (ScrollViewer + ItemsRepeater) -->
        <ScrollViewer x:Name="CardScrollViewer"
                      Visibility="{Binding IsInitializing, Converter={StaticResource InverseBoolToVisibility}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater x:Name="CardRepeater"
                           ItemsSource="{Binding DisplayCards}"
                           ItemTemplate="{StaticResource CardTemplateSelector}"
                           Margin="24,18,24,24">
                <!-- 시안 :346 — 최소 310px로 열을 채우고 남는 폭은 카드가 나눠 갖는다(최대 360).
                     ⚠️ MinItemHeight를 반드시 지정한다: 비우면 UniformGridLayout이 **첫 항목**(목록 맨 앞의
                     "새 프로젝트 추가" 카드)의 높이로 모든 셀을 고정해 나머지 카드 내용이 잘린다.
                     값 256 = 헤더 62 + 본문 여백 30 + 설명 2줄 32 + 태그 26 + 액션 34 + 슬롯 38 + 간격 36 근사.
                     이 레이아웃은 셀 크기가 균일해 행별 가변 높이가 안 되므로, 내용이 가장 많은 카드
                     (설명 2줄) 기준으로 잡는다 — 더 줄이면 그런 카드가 잘린다. -->
                <ItemsRepeater.Layout>
                    <muxc:UniformGridLayout MinItemWidth="310"
                                            MinItemHeight="256"
                                            MinColumnSpacing="14"
                                            MinRowSpacing="14"
                                            ItemsStretch="Fill"
                                            ItemsJustification="Start" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
