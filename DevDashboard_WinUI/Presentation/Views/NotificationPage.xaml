<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Presentation.Views.NotificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DevDashboard.Presentation.Views"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <!-- 알림 항목 카드 -->
        <DataTemplate x:Key="NotificationItemTemplate" x:DataType="vm:NotificationItemViewModel">
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,8"
                Tag="{x:Bind}"
                Tapped="Item_Tapped"
                Opacity="{x:Bind local:NotificationPage.ReadOpacity(IsRead), Mode=OneWay}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 안읽음 표시 점 -->
                    <Ellipse
                        Grid.Column="0"
                        Width="8" Height="8"
                        VerticalAlignment="Top"
                        Margin="0,6,0,0"
                        Fill="{ThemeResource AccentFillColorDefaultBrush}"
                        Visibility="{x:Bind local:NotificationPage.UnreadDotVisibility(IsRead), Mode=OneWay}" />

                    <!-- 작업 텍스트 + 종료일 -->
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock
                            Text="{x:Bind TodoText}"
                            TextWrapping="Wrap"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="{x:Bind local:NotificationPage.FormatDue(EndDate)}"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <!-- 마감상태 배지 + 읽음 처리 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Ellipse
                                Width="8" Height="8"
                                VerticalAlignment="Center"
                                Fill="{x:Bind local:NotificationPage.DeadlineBrush(Status)}" />
                            <TextBlock
                                Text="{x:Bind local:NotificationPage.DeadlineLabel(Status)}"
                                FontSize="11"
                                VerticalAlignment="Center"
                                Foreground="{x:Bind local:NotificationPage.DeadlineBrush(Status)}" />
                        </StackPanel>
                        <Button
                            Padding="8,4"
                            Background="Transparent" BorderThickness="0"
                            Tag="{x:Bind}"
                            Click="MarkRead_Click"
                            ToolTipService.ToolTip="{x:Bind local:NotificationPage.MarkReadTooltip}"
                            Visibility="{x:Bind local:NotificationPage.UnreadDotVisibility(IsRead), Mode=OneWay}">
                            <FontIcon Glyph="&#xE73E;" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== 헤더 ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="Back_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="{x:Bind local:NotificationPage.BackText}" />
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1" Text="{x:Bind local:NotificationPage.PageTitle}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" Margin="6,0,0,0" />

            <Button Grid.Column="3"
                    Content="{x:Bind local:NotificationPage.MarkAllText}"
                    VerticalAlignment="Center"
                    Command="{x:Bind Vm.MarkAllReadCommand}"
                    Visibility="{x:Bind Vm.HasNotifications, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
        </Grid>

        <!-- ===== 본문 ===== -->
        <Grid Grid.Row="1">
            <!-- 프로젝트별 그룹 목록 -->
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind Vm.HasNotifications, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                <ItemsControl ItemsSource="{x:Bind Vm.Groups, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NotificationProjectGroup">
                            <StackPanel Margin="0,0,0,12" MaxWidth="560" HorizontalAlignment="Left">
                                <TextBlock Text="{x:Bind ProjectName}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{x:Bind Items}" ItemTemplate="{StaticResource NotificationItemTemplate}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 빈 상태 -->
            <TextBlock
                Text="{x:Bind local:NotificationPage.EmptyText}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Visibility="{x:Bind Vm.HasNotifications, Converter={StaticResource InverseBoolToVisibility}, Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>
