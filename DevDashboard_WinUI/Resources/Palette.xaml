<?xml version="1.0" encoding="utf-8"?>
<!--
    디자인 다크 팔레트 (Phase 0 / FR-C1).
    claude.ai/design 시안(DevDashboard Redesign)의 다크 팔레트를 앱 전역에 통일 적용한다.

    적용 방식: WinUI 표준인 ThemeDictionaries 오버라이드.
    - 시스템 {ThemeResource} 브러시 키를 디자인 값으로 재정의한다(개별 화면 XAML 무수정으로 일괄 반영).
    - Color 키와 Brush 키를 함께 정의한다 — 브러시는 앱 레벨 오버라이드가 가능하지만, 색은 앱 레벨에서만
      오버라이드되므로 브러시가 참조하는 색도 재정의해야 실제 값이 바뀐다(microsoft-ui-xaml 스타일 가이드).
    - 앱은 항상 다크로 고정(Phase 0 T2)되어 WinUI가 항상 "Default"(다크) 딕셔너리를 조회하므로,
      Light/HighContrast 분기는 두지 않는다(다크 단일 — YAGNI). HighContrast는 시스템 접근성 값에 위임.

    App<PREFIX>* 토큰은 이후 Phase(설정/작업/테스트/기록/알림)에서 직접 바인딩해 재사용한다.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">

            <!-- ===== 디자인 토큰 (재사용용) ===== -->
            <Color x:Key="AppBgColor">#FF131316</Color>
            <Color x:Key="AppSurfaceColor">#FF16161A</Color>
            <Color x:Key="AppCardColor">#FF1C1C20</Color>
            <Color x:Key="AppCardAltColor">#FF222227</Color>
            <Color x:Key="AppInputColor">#FF1D1D21</Color>
            <Color x:Key="AppInputAltColor">#FF242429</Color>
            <Color x:Key="AppBorderColor">#FF26262C</Color>
            <Color x:Key="AppBorderStrongColor">#FF2E2E34</Color>
            <Color x:Key="AppBorderStrongerColor">#FF35353C</Color>
            <Color x:Key="AppAccentColor">#FFF0716A</Color>
            <Color x:Key="AppAccentHoverColor">#FFF5857E</Color>
            <Color x:Key="AppTextPrimaryColor">#FFE8E6E3</Color>
            <Color x:Key="AppTextSecondaryColor">#FFB3B0B8</Color>
            <Color x:Key="AppTextTertiaryColor">#FF8A8890</Color>
            <Color x:Key="AppTextMutedColor">#FF6F6D75</Color>
            <Color x:Key="AppTextDisabledColor">#FF5F5D66</Color>
            <Color x:Key="AppSuccessColor">#FF5DB463</Color>
            <Color x:Key="AppDangerColor">#FFF0716A</Color>
            <!-- 정보(파랑)·주의(주황) — 작업 칸반의 상태 dot(진행 중/보류)과 우선순위 배지(보통/높음)에 사용 -->
            <Color x:Key="AppInfoColor">#FF5B93D8</Color>
            <Color x:Key="AppWarningColor">#FFD9954A</Color>
            <Color x:Key="AppHoverFillColor">#FF2B2B31</Color>

            <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
            <SolidColorBrush x:Key="AppCardBrush" Color="{StaticResource AppCardColor}" />
            <SolidColorBrush x:Key="AppCardAltBrush" Color="{StaticResource AppCardAltColor}" />
            <SolidColorBrush x:Key="AppInputBrush" Color="{StaticResource AppInputColor}" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
            <SolidColorBrush x:Key="AppBorderStrongBrush" Color="{StaticResource AppBorderStrongColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppAccentHoverBrush" Color="{StaticResource AppAccentHoverColor}" />
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource AppTextPrimaryColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondaryColor}" />
            <SolidColorBrush x:Key="AppTextTertiaryBrush" Color="{StaticResource AppTextTertiaryColor}" />
            <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMutedColor}" />
            <SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource AppSuccessColor}" />
            <SolidColorBrush x:Key="AppDangerBrush" Color="{StaticResource AppDangerColor}" />
            <SolidColorBrush x:Key="AppInfoBrush" Color="{StaticResource AppInfoColor}" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="{StaticResource AppWarningColor}" />

            <!-- 배지 배경용 저채도(알파) 변형 — 같은 색상의 텍스트/dot와 짝지어 pill을 만든다 -->
            <SolidColorBrush x:Key="AppSuccessSoftBrush" Color="#285DB463" />
            <SolidColorBrush x:Key="AppInfoSoftBrush" Color="#285B93D8" />
            <SolidColorBrush x:Key="AppWarningSoftBrush" Color="#28D9954A" />
            <SolidColorBrush x:Key="AppMutedSoftBrush" Color="#286F6D75" />

            <!-- ===== 시스템 브러시 오버라이드 (직접 참조 — 전 XAML grep 전수) ===== -->
            <!-- 텍스트 -->
            <Color x:Key="TextFillColorPrimary">#FFE8E6E3</Color>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource TextFillColorPrimary}" />
            <Color x:Key="TextFillColorSecondary">#FFB3B0B8</Color>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource TextFillColorSecondary}" />
            <Color x:Key="TextFillColorTertiary">#FF8A8890</Color>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource TextFillColorTertiary}" />
            <Color x:Key="TextFillColorDisabled">#FF5F5D66</Color>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource TextFillColorDisabled}" />

            <!-- 강조(코랄) -->
            <Color x:Key="AccentFillColorDefault">#FFF0716A</Color>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource AccentFillColorDefault}" />
            <Color x:Key="AccentTextFillColorPrimary">#FFF0716A</Color>
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{StaticResource AccentTextFillColorPrimary}" />
            <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource AppAccentColor}" />

            <!-- 카드 -->
            <Color x:Key="CardBackgroundFillColorDefault">#FF1C1C20</Color>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource CardBackgroundFillColorDefault}" />
            <Color x:Key="CardBackgroundFillColorSecondary">#FF222227</Color>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{StaticResource CardBackgroundFillColorSecondary}" />
            <Color x:Key="CardStrokeColorDefault">#FF2E2E34</Color>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource CardStrokeColorDefault}" />
            <SolidColorBrush x:Key="CardStrokeColorDefaultSolidBrush" Color="{StaticResource CardStrokeColorDefault}" />

            <!-- 구분선 -->
            <Color x:Key="DividerStrokeColorDefault">#FF26262C</Color>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource DividerStrokeColorDefault}" />

            <!-- 표면(배경) -->
            <Color x:Key="SolidBackgroundFillColorBase">#FF131316</Color>
            <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource SolidBackgroundFillColorBase}" />
            <Color x:Key="SolidBackgroundFillColorSecondary">#FF16161A</Color>
            <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource SolidBackgroundFillColorSecondary}" />
            <Color x:Key="SolidBackgroundFillColorTertiary">#FF16161A</Color>
            <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource SolidBackgroundFillColorTertiary}" />
            <Color x:Key="SolidBackgroundFillColorQuarternary">#FF1C1C20</Color>
            <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource SolidBackgroundFillColorQuarternary}" />
            <Color x:Key="LayerFillColorDefault">#FF1C1C20</Color>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource LayerFillColorDefault}" />

            <!-- 미묘한 채움(hover/pressed) -->
            <Color x:Key="SubtleFillColorSecondary">#FF2B2B31</Color>
            <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource SubtleFillColorSecondary}" />
            <Color x:Key="SubtleFillColorTertiary">#FF26262C</Color>
            <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource SubtleFillColorTertiary}" />

            <!-- 컨트롤 채움/테두리 -->
            <Color x:Key="ControlFillColorDefault">#FF1D1D21</Color>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource ControlFillColorDefault}" />
            <Color x:Key="ControlFillColorSecondary">#FF222226</Color>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource ControlFillColorSecondary}" />
            <Color x:Key="ControlFillColorDisabled">#FF1A1A1E</Color>
            <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource ControlFillColorDisabled}" />
            <Color x:Key="ControlStrokeColorDefault">#FF2B2B31</Color>
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource ControlStrokeColorDefault}" />
            <Color x:Key="ControlStrokeColorSecondary">#FF35353C</Color>
            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource ControlStrokeColorSecondary}" />

            <!-- 시스템 상태 색 -->
            <Color x:Key="SystemFillColorSuccess">#FF5DB463</Color>
            <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource SystemFillColorSuccess}" />
            <Color x:Key="SystemFillColorCritical">#FFF0716A</Color>
            <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource SystemFillColorCritical}" />

            <!-- ===== 표준 컨트롤 크롬 오버라이드 (M2 — WinUI 기본 다크 #202020 잔존 방지) ===== -->
            <!-- ContentDialog (모든 다이얼로그 배경/테두리) -->
            <SolidColorBrush x:Key="ContentDialogBackground" Color="{StaticResource AppCardColor}" />
            <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="{StaticResource AppBorderStrongColor}" />
            <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="{StaticResource AppCardColor}" />
            <SolidColorBrush x:Key="ContentDialogSeparatorBorderBrush" Color="{StaticResource AppBorderColor}" />
            <SolidColorBrush x:Key="ContentDialogSmokeFill" Color="#99080808" />

            <!-- TextBox / AutoSuggestBox -->
            <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource AppInputColor}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource AppInputColor}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource AppInputAltColor}" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{StaticResource ControlFillColorDisabled}" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource AppBorderStrongColor}" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource AppBorderStrongerColor}" />

            <!-- Button -->
            <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource AppInputAltColor}" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource AppHoverFillColor}" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource AppInputColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource AppBorderStrongColor}" />

            <!-- ComboBox -->
            <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource AppInputColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource ControlFillColorSecondary}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="{StaticResource AppInputAltColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource AppBorderStrongColor}" />

        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
