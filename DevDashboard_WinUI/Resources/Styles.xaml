<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 설정 다이얼로그 세로 네비게이션 스타일 ===== -->
    <!--
        RadioButton은 내부적으로 CommonStates / CheckStates 두 그룹을 독립 호출한다.
        하나의 그룹에 복합 상태(CheckedPointerOver 등)를 정의하면 GoToState("Checked")가
        GoToState("PointerOver")를 덮어써 hover/click 이벤트가 무시되는 것처럼 보이는 버그가 발생.
        → CheckedBackground(CheckStates 담당) + HoverBackground(CommonStates 담당) 요소로 분리.
    -->
    <Style x:Key="SettingsNavItemStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,10" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <!-- CheckStates 그룹이 제어하는 선택 배경 -->
                        <Border x:Name="CheckedBackground"
                                Background="Transparent"
                                CornerRadius="6" />
                        <!-- CommonStates 그룹이 제어하는 호버/프레스 오버레이 -->
                        <Border x:Name="HoverBackground"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}"
                                              FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <!-- CheckStates 그룹이 제어하는 선택 인디케이터 -->
                        <Rectangle x:Name="ActiveIndicator"
                                   Width="3" Height="18"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   RadiusX="1.5" RadiusY="1.5"
                                   Fill="Transparent" />
                        <VisualStateManager.VisualStateGroups>
                            <!-- 포인터 상태: CheckStates와 독립적으로 동작 -->
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="HoverBackground.Background"
                                                Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="HoverBackground.Background"
                                                Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                            <!-- 선택 상태: CommonStates와 독립적으로 동작 -->
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckedBackground.Background"
                                                Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Setter Target="ActiveIndicator.Fill"
                                                Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked" />
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 그룹 탭 RadioButton 스타일 ===== -->
    <Style x:Key="GroupTabRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Height" Value="48" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="0">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background"
                                                Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background"
                                                Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="Root.BorderBrush"
                                                Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <Setter Target="Root.BorderThickness" Value="0,0,0,3" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked" />
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 그룹 추가 버튼 스타일 ===== -->
    <Style x:Key="GroupAddButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background"
                                                Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background"
                                                Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 프로젝트 카드 스타일 ===== -->
    <Style x:Key="ProjectCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- ===== 태그 배지 스타일 ===== -->
    <Style x:Key="TagBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Margin" Value="0,0,4,4" />
    </Style>

    <!-- ===== 구분선 스타일 ===== -->
    <Style x:Key="SeparatorStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="Height" Value="1" />
    </Style>

    <!-- ===== 다이얼로그 섹션 헤더 스타일 ===== -->
    <Style x:Key="DialogSectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="0,12,0,6" />
    </Style>

    <!-- ===== 입력 레이블 스타일 ===== -->
    <Style x:Key="InputLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- ===== 작업 칸반 열 패널 스타일 ===== -->
    <Style x:Key="KanbanColumnStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <!-- ===== 점선 테두리 추가 버튼 스타일 (칸반 열 하단 "새 작업") ===== -->
    <!--
        WinUI의 Border는 점선 테두리를 지원하지 않는다(StrokeDashArray는 Shape 계열 속성).
        따라서 템플릿 안에 Rectangle을 깔아 점선을 그리고 그 위에 내용을 얹는다.
        Rectangle은 Stroke가 지정돼야 StrokeDashArray가 렌더되므로 Stroke를 반드시 함께 준다.
    -->
    <Style x:Key="DashedAddButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,7" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Rectangle x:Name="DashBorder"
                                   RadiusX="8" RadiusY="8"
                                   Fill="Transparent"
                                   Stroke="{ThemeResource AppBorderStrongBrush}"
                                   StrokeThickness="1"
                                   StrokeDashArray="3,3" />
                        <ContentPresenter x:Name="Content"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="DashBorder.Stroke"
                                                Value="{ThemeResource AppAccentBrush}" />
                                        <Setter Target="Content.Foreground"
                                                Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <!-- 같은 그룹의 상태는 배타적이라 PointerOver의 Stroke가 되돌아간다 — Pressed에서도 함께 지정한다 -->
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="DashBorder.Stroke"
                                                Value="{ThemeResource AppAccentBrush}" />
                                        <Setter Target="DashBorder.Fill"
                                                Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 세그먼트 토글 스타일 (칸반/목록 전환) ===== -->
    <!--
        두 항목이 맞붙은 그룹으로 보이도록 바깥 Border가 테두리를 그리고, 각 항목은 선택 시에만 배경을 채운다.
        SettingsNavItemStyle과 동일하게 선택 배경(CheckStates)과 호버 오버레이(CommonStates)를 별도 요소로 분리한다 —
        한 요소의 같은 프로퍼티를 두 그룹이 함께 건드리면 GoToState가 서로를 덮어써
        "선택된 항목에 마우스를 올리면 선택 표시가 사라지는" 버그가 생긴다(이 파일 상단 주석 참조).
    -->
    <Style x:Key="SegmentedToggleStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <!-- CheckStates 그룹이 제어하는 선택 배경 -->
                        <Border x:Name="CheckedBackground"
                                Background="Transparent"
                                CornerRadius="5" />
                        <!-- CommonStates 그룹이 제어하는 호버/프레스 오버레이 -->
                        <Border x:Name="HoverBackground"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}"
                                              FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <!-- 포인터 상태: CheckStates와 독립적으로 동작 -->
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="HoverBackground.Background"
                                                Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="HoverBackground.Background"
                                                Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                            <!-- 선택 상태: CommonStates와 독립적으로 동작 -->
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckedBackground.Background"
                                                Value="{ThemeResource AppCardAltBrush}" />
                                        <Setter Target="Content.Foreground"
                                                Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked" />
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
