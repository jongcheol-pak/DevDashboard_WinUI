<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="DevDashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DevDashboard"
    xmlns:models="using:DevDashboard.Domain.ValueObjects"
    xmlns:vm="using:DevDashboard.Presentation.ViewModels"
    xmlns:winuiex="using:WinUIEx"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:DevDashboard.Presentation.Helpers"
    xmlns:ctrl="using:DevDashboard.Presentation.Controls"
    mc:Ignorable="d"
    Title="Project Dashboard"
    MinWidth="1000"
    MinHeight="750">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== 헤더 (타이틀 바 영역) ===== -->
        <Border x:Name="HeaderBorder"
                Grid.Row="0"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid Margin="12,0,148,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 좌: 앱 아이콘 + 타이틀 (드래그 전용 영역 — SetTitleBar 대상) -->
                <!-- SearchBox/Button이 드래그 영역에 포함되면 키보드 입력이 차단될 수 있어 분리 -->
                <Border x:Name="AppTitleBar" Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/DevDashboard.png" Width="24" Height="24"
                               Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Uid="AppTitleText" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- 중: 검색창 -->
                <AutoSuggestBox x:Name="SearchBox"
                                x:Uid="SearchBox"
                                Grid.Column="1"
                                Margin="16,0"
                                QueryIcon="Find"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                MaxWidth="400"
                               helpers:AutoSuggestBoxHelper.MaxLength="30"
                                TextChanged="SearchBox_TextChanged"
                               />

                <!-- 우: 버튼 영역 -->
                <StackPanel x:Name="HeaderButtonsPanel"
                            Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Spacing="6">

                    <!-- 정렬 버튼 -->
                    <Button x:Name="SortButton"
                            Width="36" Height="36" Padding="0"
                            IsEnabled="{Binding HasAnyProjects}">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Uid="SortByNameItem"
                                               Command="{Binding SetSortOrderCommand}"
                                               CommandParameter="{x:Bind SortByName}" />
                                <MenuFlyoutItem x:Uid="SortByCategoryItem"
                                               Command="{Binding SetSortOrderCommand}"
                                               CommandParameter="{x:Bind SortByCategory}" />
                                <MenuFlyoutItem x:Uid="SortByRecentItem"
                                               Command="{Binding SetSortOrderCommand}"
                                               CommandParameter="{x:Bind SortByDate}" />
                            </MenuFlyout>
                        </Button.Flyout>
                        <FontIcon Glyph="&#xE8CB;" FontSize="16" />
                    </Button>

                    <!-- 전체 작업 기록 버튼 -->
                    <Button x:Name="AllHistoryButton"
                            Width="36" Height="36" Padding="0"
                            IsEnabled="{Binding HasAnyProjects}"
                            Click="ProjectHistoryButton_Click">
                        <FontIcon Glyph="&#xE81C;" FontSize="16" />
                    </Button>

                    <!-- 내보내기 / 가져오기 버튼 -->
                    <Button x:Name="ExportImportButton" Width="36" Height="36" Padding="0">
                        <Button.Flyout>
                            <MenuFlyout Opening="ExportImportFlyout_Opening">
                                <MenuFlyoutItem x:Name="ExportMenuItem"
                                               x:Uid="ExportItem"
                                               Click="ExportButton_Click" />
                                <MenuFlyoutItem x:Uid="ImportItem"
                                               Click="ImportButton_Click" />
                            </MenuFlyout>
                        </Button.Flyout>
                        <FontIcon Glyph="&#xEA35;" FontSize="16" />
                    </Button>

                    <!-- 앱 설정 버튼 -->
                    <Button x:Name="AppSettingsButton"
                            Width="36" Height="36" Padding="0"
                            Click="AppSettingsButton_Click">
                        <FontIcon Glyph="&#xE713;" FontSize="16" />
                    </Button>

                    <!-- 새 프로젝트 버튼 -->
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Height="36" Padding="14,0"
                            Click="AddProjectButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock x:Uid="NewProjectText" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 메인 영역 (런처 사이드바 + 탭/콘텐츠) ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 좌: 런처 사이드바 (탭 + 콘텐츠 영역 전체 높이) -->
            <Border x:Name="LauncherSidebar"
                    Grid.Column="0"
                    Width="60"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

                <ScrollViewer Margin="0,0,0,0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="6" Padding="0,12">

                        <ItemsRepeater x:Name="LauncherRepeater">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <ctrl:LauncherItemTemplateSelector>
                                    <!-- 아이콘 템플릿 -->
                                    <ctrl:LauncherItemTemplateSelector.IconTemplate>
                                        <DataTemplate x:DataType="vm:LauncherItemViewModel">
                                            <Grid Width="44" Height="44"
                                                  HorizontalAlignment="Center"
                                                  Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  ToolTipService.ToolTip="{Binding DisplayName}"
                                                  CanDrag="True"
                                                  AllowDrop="True"
                                                  DragStarting="LauncherItem_DragStarting"
                                                  DropCompleted="LauncherItem_DropCompleted"
                                                  DragOver="LauncherItem_DragOver"
                                                  Drop="LauncherItem_Drop"
                                                  Tapped="LauncherItem_Tapped"
                                                  PointerEntered="LauncherItem_PointerEntered"
                                                  PointerExited="LauncherItem_PointerExited">
                                                <Image Source="{Binding IconImage}"
                                                       Width="28" Height="28"
                                                       Stretch="Uniform"
                                                       IsHitTestVisible="False" />
                                                <Grid.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem x:Uid="LauncherRunAsAdmin"
                                                                       Click="LauncherRunAsAdmin_Click" />
                                                        <MenuFlyoutItem x:Uid="LauncherDelete"
                                                                       Click="LauncherDelete_Click" />
                                                    </MenuFlyout>
                                                </Grid.ContextFlyout>
                                            </Grid>
                                        </DataTemplate>
                                    </ctrl:LauncherItemTemplateSelector.IconTemplate>
                                    <!-- 드롭 플레이스홀더 템플릿 -->
                                    <ctrl:LauncherItemTemplateSelector.PlaceholderTemplate>
                                        <DataTemplate x:DataType="models:DropPlaceholder">
                                            <Border Width="44" Height="44"
                                                    HorizontalAlignment="Center"
                                                    Background="{ThemeResource ControlFillColorDisabledBrush}"
                                                    BorderBrush="{ThemeResource AccentControlElevationBorderBrush}"
                                                    BorderThickness="2"
                                                    CornerRadius="4"
                                                    AllowDrop="True"
                                                    DragOver="LauncherPlaceholder_DragOver"
                                                    Drop="LauncherPlaceholder_Drop" />
                                        </DataTemplate>
                                    </ctrl:LauncherItemTemplateSelector.PlaceholderTemplate>
                                </ctrl:LauncherItemTemplateSelector>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- 추가 버튼 -->
                        <Button x:Name="LauncherAddButton"
                                Width="44" Height="44" Padding="0"
                                HorizontalAlignment="Center"
                                Click="LauncherAdd_Click"
                                AllowDrop="True"
                                DragOver="LauncherAddButton_DragOver"
                                Drop="LauncherAddButton_Drop"
                                Visibility="{Binding CanAdd, Converter={StaticResource BoolToVisibility}}">
                            <FontIcon Glyph="&#xF8AA;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 우: 그룹 탭 + 콘텐츠 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 그룹 탭 영역 -->
                <Border Grid.Row="0"
                        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 그룹 탭 좌측 스크롤 버튼 -->
                        <Button x:Name="GroupScrollLeftButton"
                                Margin="0,0,12,0"
                                Grid.Column="0"
                                Width="30" Height="30" Padding="0"
                                VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0"
                                Visibility="Collapsed"
                                Click="GroupScrollLeft_Click">
                            <FontIcon Glyph="&#xF08D;" FontSize="24" />
                        </Button>

                        <!-- 그룹 탭 스크롤 영역 -->
                        <ScrollViewer x:Name="GroupTabsScrollViewer"
                                      Grid.Column="1"

                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      ViewChanged="GroupTabsScrollViewer_ViewChanged">
                            <StackPanel x:Name="GroupTabsPanel" Orientation="Horizontal">

                                <!-- 전체 탭 -->
                                <RadioButton x:Name="AllGroupTab"
                                             x:Uid="AllGroupTab"
                                             GroupName="GroupTabs"
                                             Style="{StaticResource GroupTabRadioButtonStyle}"
                                             IsChecked="True"
                                             Checked="AllGroupTab_Checked" />

                                <!-- 사용자 그룹 탭 (코드비하인드에서 동적 추가) -->
                                <ItemsRepeater x:Name="GroupTabsRepeater"
                                               ItemsSource="{Binding Groups}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ProjectGroup">
                                            <RadioButton Content="{Binding Name}"
                                                         GroupName="GroupTabs"
                                                         Style="{StaticResource GroupTabRadioButtonStyle}"
                                                         Tag="{Binding Id}"
                                                         Checked="GroupTab_Checked"
                                                         DoubleTapped="GroupTab_DoubleTapped">
                                                <RadioButton.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem x:Uid="GroupTabRenameItem"
                                                                       Click="GroupTabRename_Click" />
                                                        <MenuFlyoutItem x:Uid="GroupTabDeleteItem"
                                                                       Click="GroupTabDelete_Click"
                                                                       Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolToVisibility}}" />
                                                    </MenuFlyout>
                                                </RadioButton.ContextFlyout>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <!-- 그룹 추가 버튼 -->
                                <Button x:Name="AddGroupButton"
                                        Style="{StaticResource GroupAddButtonStyle}"
                                        Click="AddGroupButton_Click"
                                        Visibility="{Binding CanAddGroup, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 그룹 탭 우측 스크롤 버튼 -->
                        <Button x:Name="GroupScrollRightButton"
                                Margin="12,0,0,0"
                                Grid.Column="2"
                                Padding="0"
                                Width="32" Height="32"
                                VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0"
                                Visibility="Collapsed"
                                Click="GroupScrollRight_Click">
                            <FontIcon Glyph="&#xF08F;" FontSize="24" />
                        </Button>

                        <!-- 새로고침 버튼 -->
                        <Button x:Name="RefreshButton"
                                Margin="12,0,0,0"
                                Grid.Column="3"
                                Width="32" Height="32" Padding="0"
                                VerticalAlignment="Center"
                                Command="{Binding RefreshCommand}">
                            <Button.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Uid="HardRefreshItem"
                                                   Command="{Binding HardRefreshCommand}" />
                                </MenuFlyout>
                            </Button.ContextFlyout>
                            <FontIcon Glyph="&#xE72C;" FontSize="16" />
                        </Button>
                    </Grid>
                </Border>

                <!-- 콘텐츠 영역 (DashboardView) -->
                <ContentControl Grid.Row="1" x:Name="DashboardContent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"/>
            </Grid>
        </Grid>

        <!-- ===== 하단 상태 표시줄 ===== -->
        <Border Grid.Row="2"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 좌: 런처 앱 수 + 프로젝트 수 -->
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="12" Padding="0,6">
                    <Run x:Name="LauncherCountRun" />
                    <Run x:Name="LauncherCountSuffixRun" />
                    <Run Text="  " />
                    <Run Text="{Binding ProjectCount, Mode=OneWay}" />
                    <Run x:Name="ProjectCountSuffixRun" />
                </TextBlock>

                <!-- 우: 최신 버전 안내 -->
                <HyperlinkButton x:Uid="NewVersionBanner"
                                 Grid.Column="1" VerticalAlignment="Center"
                                 FontSize="12" Padding="0,4"
                                 Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                 Visibility="{Binding HasNewVersion, Converter={StaticResource BoolToVisibility}}"
                                 Command="{Binding OpenLatestReleaseCommand}" />
            </Grid>
        </Border>
    </Grid>
</winuiex:WindowEx>
