<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Views.Dialogs.ProjectSettingsDialog"
    x:Uid="ProjectSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.ViewModels"
    xmlns:models="using:DevDashboard.Models"
    DefaultButton="Primary">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="640">
        <StackPanel Spacing="16" MinWidth="600" Padding="0,4,0,4">

            <!-- 이름 -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="ProjNameLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox
                    x:Uid="ProjNameBox"
                    Text="{x:Bind Vm.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MaxLength="100" />
            </StackPanel>

            <!-- 설명 -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="ProjDescLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox
                    x:Uid="ProjDescBox"
                    Text="{x:Bind Vm.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MaxLength="300" />
            </StackPanel>

            <!-- 그룹 + 카테고리 -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Uid="ProjGroupLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ComboBox
                        x:Uid="ProjGroupCombo"
                        ItemsSource="{x:Bind Vm.Groups, Mode=OneWay}"
                        SelectedValuePath="Id"
                        SelectedValue="{x:Bind Vm.SelectedGroupId, Mode=TwoWay}"
                        HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectGroup">
                                <TextBlock Text="{x:Bind Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock x:Uid="ProjCategoryLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ComboBox
                        x:Uid="ProjCategoryCombo"
                        ItemsSource="{x:Bind Vm.Categories, Mode=OneWay}"
                        SelectedItem="{x:Bind Vm.Category, Mode=TwoWay}"
                        HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>

            <!-- 개발 도구 -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="ProjDevToolLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ComboBox
                    x:Uid="ProjDevToolCombo"
                    ItemsSource="{x:Bind Vm.DevTools, Mode=OneWay}"
                    SelectedItem="{x:Bind Vm.SelectedDevTool, Mode=TwoWay}"
                    HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ExternalTool">
                            <TextBlock Text="{x:Bind Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- 셸 도구 전용: 명령어 + 실행 폴더 -->
            <StackPanel
                Spacing="12"
                Visibility="{x:Bind Vm.IsShellTool, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="4">
                    <TextBlock x:Uid="ProjCommandLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox
                        x:Uid="ProjCommandBox"
                        Text="{x:Bind Vm.Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        FontFamily="Consolas" />
                </StackPanel>
                <CheckBox
                    x:Uid="ProjUseWorkingDirCheck"
                    IsChecked="{x:Bind Vm.UseWorkingDirectory, Mode=TwoWay}" />
                <Grid
                    ColumnSpacing="8"
                    Visibility="{x:Bind Vm.UseWorkingDirectory, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Uid="ProjWorkingDirBox"
                        Grid.Column="0"
                        Text="{x:Bind Vm.ShellWorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        x:Uid="Btn_Browse"
                        Grid.Column="1"
                        Command="{x:Bind Vm.BrowseShellWorkingDirectoryCommand}" />
                </Grid>
            </StackPanel>

            <!-- 일반 도구 전용: 경로 + 옵션 -->
            <StackPanel
                Spacing="12"
                Visibility="{x:Bind Vm.IsShellTool, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel Spacing="4">
                    <TextBlock x:Uid="ProjPathLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Uid="ProjPathBox"
                            Grid.Column="0"
                            Text="{x:Bind Vm.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            x:Uid="ProjPathFolderBtn"
                            Grid.Column="1"
                            Command="{x:Bind Vm.BrowseFolderCommand}" />
                        <Button
                            x:Uid="ProjPathFileBtn"
                            Grid.Column="2"
                            Command="{x:Bind Vm.BrowseFileCommand}" />
                    </Grid>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock x:Uid="ProjOptionsLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox
                        x:Uid="ProjOptionsBox"
                        Text="{x:Bind Vm.Options, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </StackPanel>

            <!-- 관리자 권한 -->
            <CheckBox
                x:Uid="ProjRunAsAdminCheck"
                IsChecked="{x:Bind Vm.RunAsAdmin, Mode=TwoWay}" />

            <!-- 아이콘 -->
            <StackPanel Spacing="4">
                <TextBlock x:Uid="ProjIconLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Uid="ProjIconBox"
                        Grid.Column="0"
                        Text="{x:Bind Vm.IconPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        x:Uid="Btn_Browse"
                        Grid.Column="1"
                        Command="{x:Bind Vm.BrowseIconCommand}" />
                    <Button
                        x:Uid="Btn_Clear"
                        Grid.Column="2"
                        Command="{x:Bind Vm.ClearIconCommand}" />
                </Grid>
            </StackPanel>

            <!-- 기술 스택 태그 -->
            <StackPanel Spacing="8">
                <TextBlock x:Uid="ProjTagsLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="100">
                    <ItemsControl ItemsSource="{x:Bind Vm.AvailableTags, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TagBadgeItem">
                                <CheckBox
                                    Content="{x:Bind Name}"
                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                    Margin="0,0,8,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- 에러 -->
            <TextBlock
                x:Name="ErrorText"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Visibility="Collapsed"
                TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>

</ContentDialog>
