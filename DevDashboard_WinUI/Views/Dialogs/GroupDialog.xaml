<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DevDashboard.Views.Dialogs.GroupDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 내용 -->
        <StackPanel Grid.Row="0" Spacing="12" Padding="16,12">
            <TextBlock x:Uid="GroupNameLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBox
                x:Name="NameBox"
                x:Uid="GroupNameBox"
                Text="{x:Bind Vm.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                MaxLength="50" />
            <TextBlock
                x:Name="ErrorText"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Visibility="Collapsed"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Row 1: 버튼 패널 -->
        <Border
            Grid.Row="1"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                <Button x:Uid="Btn_Save" Click="OnSave" Style="{StaticResource AccentButtonStyle}" />
                <Button x:Uid="Btn_Cancel" Click="OnCancel" />
            </StackPanel>
        </Border>
    </Grid>

</Window>
