<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DevDashboard.Views.Dialogs.GitStatusDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevDashboard.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 내용 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
            <StackPanel Spacing="12" Loaded="OnRootLoaded">

                <!-- 로딩 중 -->
                <StackPanel
                    x:Name="LoadingPanel"
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    Padding="0,24">
                    <ProgressRing IsActive="True" Width="24" Height="24" />
                    <TextBlock x:Uid="GitLoadingText" VerticalAlignment="Center" />
                </StackPanel>

                <!-- 에러 -->
                <InfoBar
                    x:Name="ErrorBar"
                    x:Uid="GitErrorBar"
                    IsOpen="False"
                    Severity="Error"
                    IsClosable="False" />

                <!-- 로드 완료 패널 -->
                <StackPanel x:Name="ContentPanel" Spacing="12" Visibility="Collapsed">

                    <!-- 브랜치 -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xF1D3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="BranchText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Rectangle Style="{StaticResource SeparatorStyle}" />

                    <!-- 변경 파일 목록 -->
                    <TextBlock x:Uid="GitCommitHistoryLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <ItemsControl x:Name="CommitList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:GitFileStatus">
                                <Border
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="0,0,0,6">
                                    <TextBlock
                                        Text="{x:Bind FilePath}"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 커밋 없음 -->
                    <TextBlock
                        x:Name="NoCommitsText"
                        x:Uid="NoCommitsText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center"
                        Padding="0,24"
                        Visibility="Collapsed" />

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Row 1: 버튼 패널 -->
        <Border
            Grid.Row="1"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Padding="16,12">
                <Button x:Uid="Btn_Close" Click="OnClose" />
            </StackPanel>
        </Border>
    </Grid>

</Window>
