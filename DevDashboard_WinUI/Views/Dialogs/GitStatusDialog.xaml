<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Views.Dialogs.GitStatusDialog"
    x:Uid="GitStatusDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevDashboard.Models">

    <StackPanel Spacing="12" MinWidth="560">

        <!-- 로딩 중 -->
        <StackPanel
            x:Name="LoadingPanel"
            Orientation="Horizontal"
            Spacing="12"
            HorizontalAlignment="Center"
            Padding="0,24">
            <ProgressRing IsActive="True" Width="24" Height="24" />
            <TextBlock x:Uid="GitLoadingText" VerticalAlignment="Center" />
        </StackPanel>

        <!-- 에러 -->
        <InfoBar
            x:Name="ErrorBar"
            x:Uid="GitErrorBar"
            IsOpen="False"
            Severity="Error"
            IsClosable="False" />

        <!-- 로드 완료 패널 -->
        <StackPanel x:Name="ContentPanel" Spacing="12" Visibility="Collapsed">

            <!-- 브랜치 -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xF1D3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="BranchText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Rectangle Style="{StaticResource SeparatorStyle}" />

            <!-- 커밋 목록 -->
            <TextBlock x:Uid="GitCommitHistoryLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />

            <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CommitList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:GitFileStatus">
                            <Border
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,6">
                                <TextBlock
                                    Text="{x:Bind FilePath}"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 커밋 없음 -->
            <TextBlock
                x:Name="NoCommitsText"
                x:Uid="NoCommitsText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                Padding="0,24"
                Visibility="Collapsed" />

        </StackPanel>

    </StackPanel>

</ContentDialog>
