<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DevDashboard.Views.Dialogs.TodoDialog"
    x:Uid="TodoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.ViewModels"
    xmlns:models="using:DevDashboard.Models"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="500">

        <!-- 탭 바 -->
        <StackPanel Orientation="Horizontal" Spacing="0">
            <RadioButton
                x:Uid="TodoTabAll"
                IsChecked="True"
                GroupName="TodoTab"
                Style="{StaticResource GroupTabRadioButtonStyle}"
                Checked="Tab_Checked"
                Tag="All" />
            <RadioButton
                x:Uid="TodoTabActive"
                GroupName="TodoTab"
                Style="{StaticResource GroupTabRadioButtonStyle}"
                Checked="Tab_Checked"
                Tag="Active" />
            <RadioButton
                x:Uid="TodoTabDone"
                GroupName="TodoTab"
                Style="{StaticResource GroupTabRadioButtonStyle}"
                Checked="Tab_Checked"
                Tag="Completed" />
        </StackPanel>

        <!-- 새 항목 추가 -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="NewTodoBox"
                x:Uid="NewTodoBox"
                Grid.Column="0"
                MaxLength="200" />
            <Button
                x:Uid="Btn_Add"
                Grid.Column="1"
                Click="AddTodo_Click" />
        </Grid>

        <!-- 목록 -->
        <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TodoList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TodoItem">
                        <Grid Padding="0,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                Grid.Column="0"
                                Content="{x:Bind Text}"
                                IsChecked="{x:Bind IsCompleted, Mode=OneWay}"
                                Checked="TodoCheckBox_Changed"
                                Unchecked="TodoCheckBox_Changed" />
                            <Button
                                x:Uid="IconDeleteBtn"
                                Grid.Column="1"
                                Padding="8,4"
                                Tag="{x:Bind}"
                                Click="DeleteTodo_Click">
                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 빈 상태 -->
        <TextBlock
            x:Name="EmptyText"
            x:Uid="EmptyTodoText"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            HorizontalAlignment="Center"
            Padding="0,16"
            Visibility="Collapsed" />

    </StackPanel>

</ContentDialog>
