<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DevDashboard.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DevDashboard.ViewModels"
    xmlns:models="using:DevDashboard.Models"
    xmlns:ctrl="using:DevDashboard.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">

    <UserControl.Resources>

        <!-- 카드 아이콘 버튼 스타일 -->
        <Style x:Key="CardIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <!-- ───── 프로젝트 카드 DataTemplate ───── -->
        <DataTemplate x:Key="ProjectCardTemplate" x:DataType="vm:ProjectCardViewModel">
            <Border Width="330" Margin="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    CanDrag="{Binding IsPinned}"
                    AllowDrop="True"
                    DragStarting="Card_DragStarting"
                    DropCompleted="Card_DropCompleted"
                    DragOver="Card_DragOver"
                    Drop="Card_Drop">
                <Grid Margin="16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 카드 상단: 경고 + 아이콘 + 이름 + 핀 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 경로 오류 경고 -->
                        <FontIcon ToolTipService.ToolTip="Project path not found"
                                  Grid.Column="0" Glyph="&#xE7BA;" FontSize="16"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                  VerticalAlignment="Center" Margin="0,0,4,0"
                                  Visibility="{Binding IsProjectPathValid, Converter={StaticResource InverseBoolToVisibility}}" />

                        <!-- 아이콘 이미지 -->
                        <Border Grid.Column="1"
                                Width="28" Height="28" CornerRadius="4" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IconPath, Converter={StaticResource StringNotEmptyToVisibility}}">
                            <Image Source="{Binding IconSource}" Stretch="Uniform" />
                        </Border>

                        <!-- 프로젝트 이름 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Name}"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,8,0" />

                        <!-- 핀 버튼 -->
                        <Button ToolTipService.ToolTip="Pin/Unpin"
                                Grid.Column="3"
                                Style="{StaticResource CardIconButtonStyle}"
                                Command="{Binding TogglePinCommand}">
                            <Grid>
                                <FontIcon Glyph="&#xE718;" FontSize="13"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Visibility="{Binding IsPinned, Converter={StaticResource InverseBoolToVisibility}}" />
                                <FontIcon Glyph="&#xE77A;" FontSize="13"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                          Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Button>
                    </Grid>

                    <!-- 설명 -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding Description}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="34"
                               Margin="0,4,0,0"
                               Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibility}}" />

                    <!-- 태그 영역 -->
                    <ItemsRepeater Grid.Row="2" ItemsSource="{Binding Tags}" Margin="0,8,0,8">
                        <ItemsRepeater.Layout>
                            <muxc:StackLayout Orientation="Horizontal" Spacing="4" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Padding="6,3" CornerRadius="4"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <TextBlock Text="{x:Bind}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- 카드 하단 -->
                    <StackPanel Grid.Row="3" Spacing="8">

                        <!-- 개발도구 + 아이콘 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 개발도구 배지 -->
                            <Border Grid.Column="0"
                                    Background="{Binding DevToolName, Converter={StaticResource TagColor}}"
                                    CornerRadius="6" Padding="10,0" Height="34"
                                    HorizontalAlignment="Stretch" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                              Visibility="{Binding IsDevToolValid, Converter={StaticResource InverseBoolToVisibility}}" />
                                    <TextBlock Text="{Binding DevToolName}"
                                               FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- 아이콘 버튼 그룹 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" >
                                <!-- 실행 버튼 -->
                                <Button ToolTipService.ToolTip="Run"
                                       Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenInDevToolCommand}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="RunAsAdminMenuItem"
                                                           Command="{Binding OpenInDevToolAsAdminCommand}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <FontIcon Glyph="&#xE768;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 폴더 열기 -->
                                <Button ToolTipService.ToolTip="Open Folder"
                                        Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenFolderCommand}">
                                    <FontIcon Glyph="&#xE838;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 편집 -->
                                <Button ToolTipService.ToolTip="Settings"
                                        Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding EditCommand}">
                                    <FontIcon Glyph="&#xE70F;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 삭제 -->
                                <Button ToolTipService.ToolTip="Delete"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding DeleteCommand}">
                                    <FontIcon Glyph="&#xE74D;" FontSize="13"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- 커맨드 슬롯 + Git/Todo/History 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 커맨드 슬롯 버튼 (0~3) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                <!-- 슬롯 0 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                         Margin="0,0,4,0"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="0"
                                        ToolTipService.ToolTip="{Binding Cmd0Tooltip}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="0"
                                                           Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <!-- 미설정: + 아이콘 -->
                                        <FontIcon Glyph="&#xE710;" FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd0Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <!-- 설정됨: 아이콘 유무에 따라 분기 -->
                                        <Grid Visibility="{Binding IsCmd0Configured, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text=">_" FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       Visibility="{Binding HasCmd0Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                            <FontIcon Glyph="{Binding Cmd0Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd0Icon, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>

                                <!-- 슬롯 1 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                         Margin="0,0,4,0"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="1"
                                        ToolTipService.ToolTip="{Binding Cmd1Tooltip}"
                                        Visibility="{Binding IsCmd1SlotVisible, Converter={StaticResource BoolToVisibility}}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="1"
                                                           Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE710;" FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd1Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <Grid Visibility="{Binding IsCmd1Configured, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text=">_" FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       Visibility="{Binding HasCmd1Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                            <FontIcon Glyph="{Binding Cmd1Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd1Icon, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>

                                <!-- 슬롯 2 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                         Margin="0,0,4,0"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="2"
                                        ToolTipService.ToolTip="{Binding Cmd2Tooltip}"
                                        Visibility="{Binding IsCmd2SlotVisible, Converter={StaticResource BoolToVisibility}}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="2"
                                                           Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE710;" FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd2Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <Grid Visibility="{Binding IsCmd2Configured, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text=">_" FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       Visibility="{Binding HasCmd2Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                            <FontIcon Glyph="{Binding Cmd2Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd2Icon, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>

                                <!-- 슬롯 3 -->
                                <Button Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding ExecuteCommandSlotCommand}"
                                        CommandParameter="3"
                                        ToolTipService.ToolTip="{Binding Cmd3Tooltip}"
                                        Visibility="{Binding IsCmd3SlotVisible, Converter={StaticResource BoolToVisibility}}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="CmdSlotConfigureItem"
                                                           Command="{Binding ConfigureCommandSlotCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotChangeIconItem"
                                                           Command="{Binding ChangeCommandIconCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                            <MenuFlyoutItem x:Uid="CmdSlotDeleteItem"
                                                           Command="{Binding ClearCommandSlotCommand}"
                                                           CommandParameter="3"
                                                           Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <Grid>
                                        <FontIcon Glyph="&#xE710;" FontSize="13"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{Binding IsCmd3Configured, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <Grid Visibility="{Binding IsCmd3Configured, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text=">_" FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       Visibility="{Binding HasCmd3Icon, Converter={StaticResource InverseBoolToVisibility}}" />
                                            <FontIcon Glyph="{Binding Cmd3Icon}" FontSize="14"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding HasCmd3Icon, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Grid>
                                </Button>
                            </StackPanel>

                            <!-- Git / Todo / History 버튼 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="2">
                                <!-- Git 상태 (레포인 경우만) -->
                                <Button ToolTipService.ToolTip="Git Status"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding ShowGitStatusCommand}"
                                        Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibility}}">
                                    <FontIcon Glyph="&#xF1D3;" FontSize="13"
                                              FontFamily="Segoe MDL2 Assets"
                                              Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                </Button>

                                <!-- To-Do -->
                                <Button ToolTipService.ToolTip="To-Do"
                                         Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenTodoCommand}">
                                    <FontIcon Glyph="&#xE73E;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 작업 기록 -->
                                <Button ToolTipService.ToolTip="Work History"
                                         Margin="0,0,4,0"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenHistoryCommand}">
                                    <FontIcon Glyph="&#xE81C;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>

                                <!-- 터미널 열기 -->
                                <Button ToolTipService.ToolTip="Terminal"
                                        Style="{StaticResource CardIconButtonStyle}"
                                        Command="{Binding OpenTerminalCommand}">
                                    <FontIcon Glyph="&#xE756;" FontSize="13"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ───── + 추가 카드 DataTemplate ───── -->
        <DataTemplate x:Key="AddCardTemplate">
            <Border Width="330" Margin="8"
                    MinHeight="120"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Button HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="AddCard_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="28"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Uid="AddNewProjectText"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Button>
            </Border>
        </DataTemplate>

        <!-- ───── 드롭 플레이스홀더 DataTemplate ───── -->
        <DataTemplate x:Key="DropPlaceholderTemplate">
            <Border Width="330" Margin="8"
                    MinHeight="120"
                    CornerRadius="12"
                    BorderThickness="2"
                    BorderBrush="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}" />
        </DataTemplate>

        <!-- ───── Template Selector ───── -->
        <ctrl:DashboardCardTemplateSelector x:Key="CardTemplateSelector"
            ProjectCardTemplate="{StaticResource ProjectCardTemplate}"
            AddCardTemplate="{StaticResource AddCardTemplate}"
            DropPlaceholderTemplate="{StaticResource DropPlaceholderTemplate}" />

    </UserControl.Resources>

    <Grid>
        <!-- 로딩 오버레이 -->
        <Grid x:Name="LoadingOverlay"
              Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="{Binding IsInitializing}" Width="40" Height="40" />
                <TextBlock x:Uid="LoadingText" FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- 카드 목록 (ScrollViewer + ItemsRepeater) -->
        <ScrollViewer x:Name="CardScrollViewer"
                      Visibility="{Binding IsInitializing, Converter={StaticResource InverseBoolToVisibility}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater x:Name="CardRepeater"
                           ItemsSource="{Binding DisplayCards}"
                           ItemTemplate="{StaticResource CardTemplateSelector}"
                           Margin="8,8,8,8">
                <ItemsRepeater.Layout>
                    <muxc:UniformGridLayout  ItemsJustification="Start" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
